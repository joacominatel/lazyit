# --- Root environment (read by docker-compose.yml) ---
# Copy to `.env` and fill in. These configure the Postgres dev container.
POSTGRES_USER=postgres
# Set a non-trivial password even in dev (Postgres fails closed if this is empty). Production
# must never reuse example credentials nor publish port 5432 — see ADR-0028 / SEC-005.
POSTGRES_PASSWORD=
# Database name. Defaults to "lazyit" if left unset.
POSTGRES_DB=lazyit

# NOTE: the API has its own env file — see apps/api/.env.example (DATABASE_URL, PORT).
# A fresh clone needs BOTH this root .env and apps/api/.env.
