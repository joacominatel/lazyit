# --- Root environment (read by docker-compose.yml) ---
# Copy to `.env` and fill in. These configure the Postgres dev container.
POSTGRES_USER=postgres
# Set a non-trivial password even in dev (Postgres fails closed if this is empty). Production
# must never reuse example credentials nor publish port 5432 — see ADR-0028 / SEC-005.
POSTGRES_PASSWORD=
# Database name. Defaults to "lazyit" if left unset.
POSTGRES_DB=lazyit

# Meilisearch (search engine) master key — read by docker-compose.yml. Set a strong key even in dev;
# the API authenticates to Meili with the same value (apps/api/.env MEILI_MASTER_KEY). See ADR-0035.
MEILI_MASTER_KEY=

# NOTE: the API has its own env file — see apps/api/.env.example (DATABASE_URL, PORT).
# A fresh clone needs BOTH this root .env and apps/api/.env.

# ── Zitadel IdP (dev) ────────────────────────────────────────────────────────────────────
# Zitadel gets its own Postgres — separate from the app DB (ADR-0037). This prevents
# Zitadel's aggressive schema migrations from touching the app DB, and gives a clean
# removal path if a customer brings their own IdP (BYOI — change 3 env vars, done).

# Zitadel's own Postgres credentials (used by both the zitadel_db and zitadel containers)
ZITADEL_DB_USER=zitadel
ZITADEL_DB_PASSWORD=change_me
ZITADEL_DB_NAME=zitadel

# Master key — min 32 chars, random, never reuse across environments.
# Generate: openssl rand -base64 32
ZITADEL_MASTERKEY=change_me_32_chars_minimum_here_xx

# External hostname Zitadel advertises in OIDC tokens and redirects.
# Dev: localhost (no HTTPS). Prod: auth.yourdomain.com (see infra/env/.env.prod.example).
ZITADEL_EXTERNALDOMAIN=localhost

# First-boot admin user — created on `start-from-init`, only used once.
# Password must meet Zitadel's complexity: min 8 chars, upper + lower + digit + symbol.
ZITADEL_ADMIN_USERNAME=admin
ZITADEL_ADMIN_PASSWORD=Admin1234!

# ── OIDC client (set AFTER Zitadel is configured — see docs/05-runbooks/auth-bootstrap.md) ──
# These are read by the API (apps/api/.env) — add them there once you have the values.
# Placeholders here for discoverability; the real values live in apps/api/.env (gitignored).
OIDC_ISSUER=http://localhost:8080
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
