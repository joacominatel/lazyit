# --- @lazyit/api environment ---
# Copy to `apps/api/.env` and fill in. Bun auto-loads .env for the app; the Prisma CLI
# reads DATABASE_URL via prisma.config.ts (which imports dotenv/config).

# Postgres connection used by Prisma. Credentials/db must match the root .env
# (POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB) and the compose service on :5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lazyit?schema=public"

# Port the NestJS API listens on.
PORT=3001

# Express `trust proxy` hop count (SEC-010). Controls how `req.ip` (which keys the /config/setup
# rate-limiter + the first-run audit IP) is derived from X-Forwarded-For. Leave UNSET in dev: with no
# reverse proxy, `req.ip` is the socket address and a forged X-Forwarded-For is ignored. Behind a
# reverse proxy set it to the number of proxy hops (Caddy = 1). NEVER set "true" on a public origin
# where the client can reach the API directly (it would trust a spoofed XFF).
# TRUST_PROXY=1

# Log format (ADR-0031): unset / any non-"production" value => pretty, human-readable dev logs;
# "production" => structured JSON. The prod container sets NODE_ENV=production; leave it unset locally.
# NODE_ENV=production

# Allowed CORS origin — the web app's URL. Used by app.enableCors() in main.ts.
WEB_ORIGIN="http://localhost:3000"

# Max size (MB) for the article import endpoint (POST /articles/import). Default 5 if unset.
MAX_IMPORT_SIZE_MB=5

# --- Async workers / BullMQ (ADR-0053) ---
# Redis-protocol URL for the self-hosted Valkey (Redis-compatible) engine that backs the job queue.
# The compose service `valkey` listens on :6379; compose.override.yaml publishes 127.0.0.1:6379 for
# native `bun run dev`. Powers the async article import (POST /articles/import → 202 + jobId, polled
# at GET /articles/import/:jobId). Defaults to redis://127.0.0.1:6379 if unset.
REDIS_URL="redis://127.0.0.1:6379"

# Node heap cap (MB) for the SANDBOXED .docx import worker child (SEC-002). A decompression bomb
# expands past this and OOMs the isolated child, never the API. Default 256 if unset/invalid.
# IMPORT_CHILD_HEAP_MB=256

# --- Applications Workflow Engine secrets (ADR-0054, epic #248) ---
# AES-256-GCM master key for the engine's OWN encrypted credential store (WorkflowSecret) — the
# per-app connector credentials (Jira tokens, OAuth secrets, webhook signing keys). This is a SECRET;
# it is NEVER logged. Must decode to EXACTLY 32 bytes — 64 hex chars (preferred), base64 of 32 bytes,
# or a 32-char raw string. Generate one with: openssl rand -hex 32
# The API FAILS LOUD AT BOOT if the workflow engine is enabled and this is missing or the wrong length
# (a half-configured secret store is worse than an absent one). Losing this key = losing every stored
# connector credential (recoverable only by re-entering them — see docs/05-runbooks/backups.md). It is
# a SEPARATE key axis from the Settings store: one key per subsystem.
WORKFLOW_SECRET_KEY=

# Meilisearch (ADR-0035). MEILI_HOST = the engine URL; MEILI_MASTER_KEY must match the root .env.
# The compose service `meilisearch` listens on :7700. Search degrades gracefully when Meili is
# unreachable (index sync is fire-and-forget). If MEILI_HOST is unset, search wiring is disabled.
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY=

# OIDC / Auth (ADR-0037, ADR-0038). The guard lives at apps/api/src/auth/jwt-auth.guard.ts.
# AUTH_MODE=shim uses the X-User-Id header (dev/tests). Unset (or any other value) = OIDC mode
# (production default). NEVER run production with AUTH_MODE=shim — the header is forgeable.
AUTH_MODE=shim
# OIDC issuer URL — set after Zitadel is bootstrapped (see docs/05-runbooks/auth-bootstrap.md).
# BYOI: replace OIDC_ISSUER + OIDC_CLIENT_ID with your existing IdP values. No code changes needed.
OIDC_ISSUER=
# OIDC_CLIENT_ID — optional. If set, the guard validates the token `aud` against it; if unset,
# audience validation is skipped (some IdPs put a resource audience on access tokens, not the client id).
OIDC_CLIENT_ID=
# OIDC_JWKS_URI — optional. The JWKS URL the guard fetches signing keys from. Leave UNSET to derive
# it from the issuer (`${OIDC_ISSUER}/.well-known/jwks.json`). Set it ONLY for the Docker split-DNS
# case, when JWKS must be fetched from an internal origin the issuer host doesn't resolve to — e.g.
# OIDC_JWKS_URI=http://zitadel:8080/oauth/v2/keys. When set, discovery + userinfo are also rewritten
# to that internal origin (with X-Forwarded-* derived from OIDC_ISSUER). See auth-bootstrap.md.
# OIDC_JWKS_URI=
#
# NOTE: the API does NOT read an OIDC client secret. The client secret is the WEB's responsibility
# (apps/web/.env → AUTH_CLIENT_SECRET, used by Auth.js for the authorization-code exchange).

# Identity provider for IdP write-back (ADR-0043). Selects the IdentityProvider implementation the
# auth epic uses to MIRROR lazyit's user/role decisions into the IdP. Authorization is ALWAYS DB-first
# (the RolesGuard reads roles from the local DB, never from a token), so this only controls the mirror.
#   zitadel      — lazyit's recommended self-hosted IdP; management write-back (Phase 2; STUB for now).
#   generic-oidc — BYOI: management degrades to a no-op (lazyit DB stays the role source).
# Unset or unrecognized → defaults to zitadel.
IDENTITY_PROVIDER_TYPE=zitadel

# --- Zitadel Management write-back (ADR-0043 Phase 2) ---
# Only used when IDENTITY_PROVIDER_TYPE=zitadel. These wire the runtime API -> Zitadel Management API
# (v2) so lazyit MIRRORS its user/role decisions into Zitadel (create user, grant/revoke role,
# deactivate). They are NEVER on the login path: if any of them is missing/misconfigured the app boots
# and logs in normally — only the write-back mirror is disabled (a structured WARN is logged and the
# Users write surfaces 503 rather than a silent partial write). With IDENTITY_PROVIDER_TYPE=generic-oidc
# these are ignored (management is a no-op). LEAVE ALL UNSET until Zitadel is provisioned.
#
# The Zitadel project whose roles (ADMIN / MEMBER / VIEWER) lazyit grants. Required for write-back.
# ZITADEL_MGMT_PROJECT_ID=
#
# The internal origin the API reaches Zitadel at (Docker split-DNS). Defaults to the origin of
# OIDC_JWKS_URI, then OIDC_ISSUER. The JWT `aud` + the forwarded host stay the EXTERNAL issuer
# (X-Forwarded-Host/Proto derived from OIDC_ISSUER) so Zitadel resolves the right instance — mirrors
# the JWKS/userinfo handling in jwt-auth.guard.ts.
# ZITADEL_MGMT_API_URL=http://zitadel:8080
#
# The service-account machine KEY used to authenticate to the Management API (Private-Key JWT, RS256,
# RFC 7523 jwt-bearer — ADR-0043 decision #4). This is a SECRET; it is NEVER logged. Supply it EITHER
# inline as the JSON Zitadel emits (type/keyId/key/userId)...
# ZITADEL_MGMT_SA_KEY='{"type":"serviceaccount","keyId":"...","key":"-----BEGIN RSA PRIVATE KEY-----\n...","userId":"..."}'
# ...OR as a path to a mounted secret file containing that JSON (preferred in prod; the file is
# provisioned by the Phase-3 zitadel-bootstrap sidecar — set this MANUALLY for now):
# ZITADEL_MGMT_SA_KEY_PATH=/zitadel-secrets/api-key.json

# --- First-run setup wizard CSRF (ADR-0043 Phase 3) ---
# Signing key for the stateless CSRF tokens that gate POST /config/setup (the public first-run
# bootstrap). OPTIONAL: when unset, the API derives a random per-boot key — fine for a single-instance
# first-run (the wizard completes within one server lifetime). Set this only if you run MULTIPLE API
# replicas serving the wizard, so a token issued by one replica verifies on another. Not a
# confidentiality secret (these are anti-CSRF nonces), but treat it like one.
# SETUP_CSRF_SECRET=
