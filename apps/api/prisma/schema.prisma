// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  // Prisma 7's client is ESM by default; NestJS runs CommonJS. Emit CJS to match.
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// A person in the organization. Central to access, peripheral to assets:
/// users come and go while assets persist. See docs/02-domain/entities/user.md
model User {
  id             String    @id @default(uuid()) @db.Uuid
  // Case-insensitive (citext, ADR-0041): "Bob@x" and "bob@x" are the same address, so OIDC/JIT can
  // never mint two users from one mailbox. UNIQUENESS is a PARTIAL unique index WHERE "deletedAt" IS
  // NULL (raw SQL in the migration — Prisma can't express partial uniques), so a soft-deleted user
  // frees its email for reuse and Restore can reclaim it. No `@unique` here: that would emit a FULL
  // unique index, re-introducing the ghost-row collision. Follows the AssetAssignment precedent.
  email          String    @db.Citext
  firstName      String
  lastName       String
  isActive       Boolean   @default(true)
  // RBAC role (ADR-0040, default flipped by ADR-0043). Default VIEWER (least-privilege): app-created
  // users AND non-first JIT users land read-only until an ADMIN promotes them. The first JIT user /
  // seed still becomes ADMIN so a fresh install is never un-administrable. The RolesGuard gates
  // Access-grant writes, Users administration and destructive deletes to ADMIN; VIEWER is read-only.
  // Only an ADMIN (via the ADMIN-gated Users controller) can change a role.
  role           Role      @default(VIEWER)
  // Maps to the IdP `sub` once auth is integrated; null until then (no auth yet).
  // Nullable + unique: many users may be unlinked, but a linked sub is 1:1. See ADR-0016.
  externalId     String?   @unique
  // Employee/file number (LATAM payroll/HR) — ADR-0058. Optional; stored verbatim (trim on write).
  // UNIQUE among LIVE rows only via a PARTIAL unique index `WHERE "deletedAt" IS NULL` (raw SQL in the
  // migration, no `@unique`), so a soft-deleted user frees its legajo for reuse/restore, exactly like
  // `email` (ADR-0041). lazyit never parses it.
  legajo         String?
  // Human-facing directory/display handle distinct from email/externalId — ADR-0058. Optional.
  // Normalized on write (trim + lowercase, like email) so `Ana`/`ana` collide. Same LIVE-only partial
  // unique index. NOT an auth credential (auth stays the IdP's job, ADR-0016/0043) and NEVER an
  // account-linking key (that stays email/externalId, INV-2) — a directory/display field only.
  username       String?
  // Manager when they ARE a lazyit user — ADR-0058. Self-FK → User, onDelete: SetNull (a hard delete
  // never blocks/dangles; soft delete is an UPDATE deletedAt and never fires onDelete, so a report keeps
  // pointing at a soft-deleted manager — the read layer surfaces that as isOffboarded, never a dangle).
  // Mutually exclusive with `managerName`: a DB CHECK `users_manager_at_most_one` enforces at-most-one
  // (both-null = "no manager recorded"), mirroring the at-most-one-actor CHECKs (ADR-0048). A DB CHECK
  // `users_manager_not_self` forbids managerId = id; the SERVICE additionally rejects a cycle (DFS up).
  managerId      String?   @db.Uuid
  manager        User?     @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  // Free-text fallback when the manager is NOT a lazyit user — ADR-0058 (the manager is in HR's system,
  // not IT's). Normalized (trim). Mutually exclusive with `managerId`.
  managerName    String?
  // Directory-only person (ADR-0069 amendment / ADR-0038 amendment): a row created by the bulk import
  // for an asset's "assigned to" that has NO login and NO Zitadel mirror (externalId stays null, role
  // stays VIEWER). It IS a User so AssetAssignment.userId (uuid FK) points at it with zero schema churn.
  // EXCLUDED from the bootstrap first-user→ADMIN count (jwt-auth.guard.ts:365) so importing people can
  // never hand ADMIN to a non-login row. Flips to false when the person first signs in via OIDC and the
  // verified-email claim links this row (ADR-0038). HARD RULE: a directoryOnly row is NEVER the subject
  // of an AccessGrant / external provisioning (access-grants.assertUserUsable rejects it) — see INVARIANTS.
  // ponytail: User and a directory person share one table on purpose — a directory person is a User
  // without a login, not a new entity. Ceiling: no per-attribute validation on directoryAttrs, no SQL
  // filter/sort by department. Upgrade path: promote directoryAttrs keys to real columns if a reader needs
  // to query them; fork a Person model only if directory semantics ever truly diverge.
  directoryOnly  Boolean   @default(false)
  // Free-form directory attributes for a directory-only person (cargo/jobTitle, departamento, teléfono,
  // and any person sub-field with no native home). Same posture as Asset.specs (ADR-0007): jsonb,
  // optional, only populated on directory rows. NOT validated per-field in this MVP.
  directoryAttrs Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  // Direct reports — the inverse of the `manager` self-relation (ADR-0058). A user has many reports;
  // each report's `managerId` points back here. No cascade behaviour beyond the FK's SetNull above.
  reports User[] @relation("UserManager")

  // Asset ownership over time (three roles: owner, who-assigned, who-released). See AssetAssignment.
  assignments         AssetAssignment[] @relation("AssignmentOwner")
  assignmentsMade     AssetAssignment[] @relation("AssignmentAssignedBy")
  assignmentsReleased AssetAssignment[] @relation("AssignmentReleasedBy")

  // Knowledge Base authorship: articles this user authored, and articles they last edited.
  articlesAuthored Article[] @relation("ArticleAuthor")
  articlesEdited   Article[] @relation("ArticleLastEditor")

  // KB versioning (ADR-0042): article snapshots this user produced (ArticleVersion.editedById,
  // SetNull) and article<->asset/application links this user created (ArticleLink.createdById, SetNull).
  articleVersionsEdited ArticleVersion[] @relation("ArticleVersionEditor")
  articleLinksCreated   ArticleLink[]    @relation("ArticleLinkCreator")

  // Access management: applications this user holds grants on, plus grants they granted/revoked.
  accessGrants        AccessGrant[] @relation("AccessGrantUser")
  accessGrantsGranted AccessGrant[] @relation("AccessGrantGrantedBy")
  accessGrantsRevoked AccessGrant[] @relation("AccessGrantRevokedBy")

  // Asset events this user caused (AssetHistory.performedById). SetNull keeps the log on deletion.
  assetHistoryActed AssetHistory[] @relation("AssetHistoryActor")

  // This user's own append-only lifecycle log (UserHistory.userId — DEBT-2, issue #185). The user is
  // the SUBJECT here. Required FK with Restrict on the subject side preserves a user's history (soft
  // delete UPDATEs deletedAt and bypasses it), mirroring AssetHistory's subject relation to Asset.
  history          UserHistory[] @relation("UserHistorySubject")
  // User lifecycle events this user CAUSED (UserHistory.performedById — the actor side). SetNull keeps
  // the append-only row when the actor is deleted, mirroring assetHistoryActed.
  userHistoryActed UserHistory[] @relation("UserHistoryActor")

  // Consumable stock movements this user performed (ConsumableMovement.performedById). SetNull.
  consumableMovements ConsumableMovement[] @relation("ConsumableMovementActor")

  // Permission-matrix edits this user performed (PermissionAuditLog.actorId). SetNull keeps the
  // append-only audit row when the actor is deleted (ADR-0046 P5). null = system/unknown actor.
  permissionAuditEntries PermissionAuditLog[] @relation("PermissionAuditActor")

  // Service accounts this user created + the ServiceAccount lifecycle events they performed (ADR-0048).
  // SetNull on both: deleting the user keeps the (soft-deletable) account and the append-only audit row.
  serviceAccountsCreated     ServiceAccount[]         @relation("ServiceAccountCreator")
  serviceAccountAuditEntries ServiceAccountAuditLog[] @relation("ServiceAccountAuditActor")

  // Applications Workflow Engine (ADR-0054, epic #248). The human-actor sides of the engine's
  // attribution columns — all SetNull, so deleting the user never blocks deletion and the
  // append-only run/version rows survive: workflow definitions this user authored
  // (WorkflowVersion.createdById), runs they caused by granting/revoking access
  // (WorkflowRun.triggeredById), and manual tasks assigned to / completed by them.
  workflowVersionsAuthored WorkflowVersion[] @relation("WorkflowVersionAuthor")
  workflowRunsTriggered    WorkflowRun[]     @relation("WorkflowRunTriggeredBy")
  manualTasksAssigned      ManualTask[]      @relation("ManualTaskAssignee")
  manualTasksCompleted     ManualTask[]      @relation("ManualTaskCompletedBy")

  // In-app notification bell (ADR-0056). Notifications this user is the SUBJECT of (the grantee /
  // the elevated user — Notification.targetUserId, SetNull so deletion never blocks), notifications
  // TARGETED at this user's own bell (Notification.recipientUserId, SetNull — ADR-0056 amendment, #453),
  // and the per-admin read joins this user owns (NotificationRead.userId, Cascade — deleting the user
  // drops only their read rows, never the events).
  notificationsTargeting Notification[]     @relation("NotificationTargetUser")
  notificationsReceiving Notification[]     @relation("NotificationRecipientUser")
  notificationReads      NotificationRead[] @relation("NotificationReader")

  // Secret Manager — zero-knowledge vaults (ADR-0061, #366). This user's single keypair (1:1,
  // UserKeypair.userId Cascade — drop the keypair when the user is hard-deleted), the vault
  // memberships carrying a DEK wrapped to this user's public key (VaultMembership.userId Cascade —
  // a wrapped-DEK copy is meaningless without its owner), and the append-only audit rows this user
  // ACTED on (SecretAuditLog.actorId, SetNull — the metadata row survives the actor's deletion). The
  // server holds wrapped blobs + ciphertext only; it can NEVER decrypt a value (INV-10).
  keypair          UserKeypair?
  vaultMemberships VaultMembership[] @relation("VaultMembershipUser")
  secretAuditActed SecretAuditLog[]  @relation("SecretAuditActor")

  // Migrator import (ADR-0069, #627): the import sessions this user owns (Restrict — don't orphan an
  // in-flight import) and the commit runs this user triggered (ImportRun.actorId, SetNull — the audit
  // ledger survives the actor's deletion).
  importSessions ImportSession[] @relation("ImportSessionOwner")
  importRuns     ImportRun[]     @relation("ImportRunActor")

  @@map("users")
}

/// RBAC role for a User (ADR-0040). A single coarse-grained role, NOT a per-resource ACL matrix
/// (explicitly rejected for the 5–20-person target). Enforced by the RolesGuard composing after the
/// auth guard:
///   - ADMIN  — full access, including Access-grant writes, Users administration and destructive deletes.
///   - MEMBER — normal inventory / KB / asset operations; NOT Access-grant writes, Users admin or deletes.
///   - VIEWER — read-only everywhere; cannot mutate anything.
enum Role {
  ADMIN
  MEMBER
  VIEWER
}

/// Roles & Permissions v2 (ADR-0046) — the FOUNDATION. A configurable mapping from each fixed
/// `Role` to the fine-grained `domain:action` permissions it holds. The 3 roles stay fixed
/// (ADR-0040); only the PERMISSIONS behind them become configurable. This table is purely additive
/// in this wave: nothing consumes it yet (the `@RequirePermission` guard is a later wave) — it is
/// the seed/contract groundwork, behavior-preserving.
///
/// `permission` is a plain String (not an enum) deliberately: the closed catalog lives as zod in
/// `@lazyit/shared` (`PermissionSchema`), so the DB stays a flat key/value store the seed and a
/// future config endpoint write 1:1 — adding a permission never needs an enum migration. INV-1
/// (ADR-0043 #1): authorization resolves from THESE rows, never a token claim. The ADMIN row set is
/// the COMPLETE catalog and is immutable/full (the future config surface must never edit it).
/// Append-only-ish config (no soft delete / timestamps): the composite PK is the row's identity.
model RolePermission {
  role       Role
  permission String

  @@id([role, permission])
  @@map("role_permissions")
}

/// Roles & Permissions v2 (ADR-0046, P5) — the append-only audit trail of every per-role permission
/// edit made through the ADMIN config surface (PUT /config/permissions). One row per permission
/// GRANTED or REVOKED on a role, so the matrix's full edit history is reconstructable. Auditability
/// by default (ADR-0006): immutable — `createdAt` only, NO updatedAt / deletedAt, never updated or
/// deleted. The ADMIN row is immutable in the endpoint, so only MEMBER/VIEWER edits land here.
model PermissionAuditLog {
  // autoincrement: a log table, never exposed externally (ADR-0005).
  id         Int                   @id @default(autoincrement())
  // Who made the edit — the authenticated ADMIN's User.id. SetNull (mirrors AssetHistory.performedBy):
  // deleting the actor never blocks deletion and the audit row survives. null = system/unknown.
  // @db.Uuid to match User.id.
  actorId    String?               @db.Uuid
  actor      User?                 @relation("PermissionAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  // The role whose permission set changed (MEMBER or VIEWER — ADMIN is immutable, never audited here).
  role       Role
  // The catalog permission literal (`domain:action`) granted or revoked. Plain String, mirroring
  // RolePermission.permission — the closed catalog lives as zod in @lazyit/shared.
  permission String
  // Whether the permission was added to (GRANT) or removed from (REVOKE) the role's set.
  action     PermissionAuditAction
  createdAt  DateTime              @default(now())

  // No updatedAt / deletedAt: append-only (ADR-0006). Indexed for the per-role / chronological audit query.
  @@index([role, id])
  @@map("permission_audit_log")
}

/// The two directions a permission edit can take (ADR-0046 P5). GRANT = the permission was added to a
/// role's set on a PUT; REVOKE = it was removed. The ADMIN-immutable / catalog-membership guardrails
/// are enforced before any row is written.
enum PermissionAuditAction {
  GRANT
  REVOKE
}

/// A NON-HUMAN principal (ADR-0048): a CI runner, a script, an integration that calls the lazyit API
/// without a person behind it. Deliberately a SEPARATE entity from `User` (not a `type` flag, not a
/// Zitadel machine-user), so the human table — JIT provisioning, the last-admin / first-admin
/// invariants, `externalId` linkage — stays untouched. A service account NEVER has a `Role` and is
/// NEVER ADMIN-equivalent; it is authorized solely by its direct `ServiceAccountPermission` grants.
///
/// AUTH (ADR-0048): authenticates with a LAZYIT-NATIVE token `lzit_sa_<id>_<secret>` (BYOI-safe — no
/// IdP dependency). The secret is high-entropy (`crypto.randomBytes(32)` base64url), so only its
/// SHA-256 `tokenHash` (+ a short non-secret `tokenPrefix` for display) is stored; the cleartext token
/// is shown ONCE on create/rotate and is never recoverable. The JwtAuthGuard SA branch (runs BEFORE
/// the OIDC branch) looks the row up by id and constant-time-compares SHA-256(secret) to `tokenHash`.
///
/// `id` is `cuid()` (a domain entity, embedded in the token — ADR-0005). Soft-deletable (ADR-0006):
/// DELETE sets `deletedAt` (= REVOKE), POST /restore clears it. `tokenHash` is unique among LIVE rows
/// only — a PARTIAL unique index WHERE "deletedAt" IS NULL (raw SQL in the migration; Prisma can't
/// express it), mirroring the soft-delete-reuse precedent (ADR-0041): no `@unique` (that re-introduces
/// the ghost-row collision). See docs/03-decisions/0048-service-accounts.md.
model ServiceAccount {
  id          String    @id @default(cuid())
  name        String
  description String?
  // SHA-256 hash of the token secret (hex). The cleartext secret is NEVER stored. Unique among LIVE
  // rows via a PARTIAL unique index (raw SQL); rotate replaces this with the new secret's hash.
  tokenHash   String
  // A short, non-secret display fragment of the token (e.g. "lzit_sa_ckg9…"). Surfaced in the UI so an
  // operator can recognise a credential; reveals nothing usable. Refreshed on rotate.
  tokenPrefix String
  // Soft disable distinct from revoke (deletedAt). An inactive account authenticates → 401, like an
  // expired one, but its row and grants are preserved for re-enable. Default active.
  isActive    Boolean   @default(true)
  // Optional expiry (ADR-0048): a token presented at/after this instant is rejected (401). No
  // scheduler force-expires; the guard checks it at auth time. null = no expiry.
  expiresAt   DateTime?
  // Set (best-effort, fire-and-forget) on each successful authentication. null until first use.
  lastUsedAt  DateTime?
  // The human who created it — the authenticated ADMIN's User.id. SetNull (mirrors AssetHistory):
  // deleting that user never blocks deletion and the row survives. @db.Uuid to match User.id.
  createdById String?   @db.Uuid
  createdBy   User?     @relation("ServiceAccountCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Direct permission grants (the authorization source — never a role).
  permissions ServiceAccountPermission[]
  // Append-only audit trail of mint / rotate / revoke / restore / permission-change.
  auditLog    ServiceAccountAuditLog[]

  // Append-only actor attribution (ADR-0048): rows this service account authored on the audit-bearing
  // tables. SetNull keeps the log row when the account is hard-deleted (which never happens — soft
  // delete only). Mirrors the human-actor back-relations on User.
  assetHistoryActed     AssetHistory[]       @relation("AssetHistorySaActor")
  userHistoryActed      UserHistory[]        @relation("UserHistorySaActor")
  consumableMovements   ConsumableMovement[] @relation("ConsumableMovementSaActor")
  assignmentsMade       AssetAssignment[]    @relation("AssignmentAssignedBySa")
  assignmentsReleased   AssetAssignment[]    @relation("AssignmentReleasedBySa")
  accessGrantsGranted   AccessGrant[]        @relation("AccessGrantGrantedBySa")
  accessGrantsRevoked   AccessGrant[]        @relation("AccessGrantRevokedBySa")
  articleVersionsEdited ArticleVersion[]     @relation("ArticleVersionEditorSa")
  articleLinksCreated   ArticleLink[]        @relation("ArticleLinkCreatorSa")

  // Applications Workflow Engine (ADR-0054, epic #248). The service-account-actor sides of the
  // engine's attribution columns — all SetNull. A workflow runs AS a dedicated least-privilege
  // engine SA (ApplicationWorkflow.executedAsServiceAccountId, copied onto
  // WorkflowRun.executedAsServiceAccountId), an SA may TRIGGER a run by granting/revoking access
  // (WorkflowRun.triggeredBySaId), author a definition (WorkflowVersion.createdBySaId) or complete
  // a manual task (ManualTask.completedBySaId). Never a fabricated human, never ADMIN (INV-SA-2/4).
  workflowsAsEngine        ApplicationWorkflow[] @relation("ApplicationWorkflowEngineSa")
  workflowVersionsAuthored WorkflowVersion[]     @relation("WorkflowVersionAuthorSa")
  workflowRunsTriggered    WorkflowRun[]         @relation("WorkflowRunTriggeredBySa")
  workflowRunsExecutedAs   WorkflowRun[]         @relation("WorkflowRunExecutedAsSa")
  manualTasksCompleted     ManualTask[]          @relation("ManualTaskCompletedBySa")

  // Programmatic secret retrieval (ADR-0080, extends ADR-0061 + ADR-0048). The SA's X25519 crypto
  // identity (1:1) + the vaults it is a crypto member of (wrapped-DEK rows). BOTH hold ONLY ciphertext /
  // public material — the server can never decrypt (INV-10). Cascade on both sides: a keypair / wrapped-
  // DEK row is meaningless without its service account (a — never-issued — hard delete drops them).
  keypair          ServiceAccountKeypair?
  vaultMemberships ServiceAccountVaultMembership[]

  @@index([isActive])
  @@map("service_accounts")
}

/// A single direct permission grant for a ServiceAccount (ADR-0048). The authorization source: a
/// service account passes a `@RequirePermission` route only if it holds EVERY required permission in
/// THIS set — never via a role. `permission` is a plain String (not an enum), mirroring RolePermission:
/// the closed catalog lives as zod in `@lazyit/shared` (`PermissionSchema`), so adding a permission
/// never needs an enum migration and a catalog-foreign row is ignored at resolution time. The composite
/// PK (serviceAccountId, permission) makes a grant idempotent. Cascade on the account: grants are
/// meaningless without their account and carry no independent audit value (the ServiceAccountAuditLog
/// records the change history), and the account itself soft-deletes — this cascade only fires on a
/// (never-issued) hard delete.
model ServiceAccountPermission {
  serviceAccountId String
  serviceAccount   ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)
  permission       String

  @@id([serviceAccountId, permission])
  @@index([serviceAccountId])
  @@map("service_account_permissions")
}

/// Append-only audit trail of every lifecycle event on a ServiceAccount (ADR-0048): MINT (create),
/// ROTATE (new secret), REVOKE (soft delete), RESTORE, and PERMISSION_CHANGE. Auditability by default
/// (ADR-0006): immutable — `createdAt` only, never updated or deleted. `actorId` is the ADMIN who
/// performed it (SetNull, like PermissionAuditLog). `detail` is optional contextual jsonb (e.g. the
/// added/removed permissions on a PERMISSION_CHANGE). The secret is NEVER recorded here.
model ServiceAccountAuditLog {
  // autoincrement: a log table, never exposed externally (ADR-0005).
  id               Int                       @id @default(autoincrement())
  serviceAccountId String
  serviceAccount   ServiceAccount            @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)
  action           ServiceAccountAuditAction
  // Who performed it — the authenticated ADMIN's User.id. SetNull. @db.Uuid to match User.id. null =
  // system/unknown actor.
  actorId          String?                   @db.Uuid
  actor            User?                     @relation("ServiceAccountAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  // Optional contextual jsonb (e.g. { added: [...], removed: [...] } on PERMISSION_CHANGE). Never a secret.
  detail           Json?
  createdAt        DateTime                  @default(now())

  // No updatedAt / deletedAt: append-only (ADR-0006). (serviceAccountId, id) serves the per-account
  // chronological audit query.
  @@index([serviceAccountId, id])
  @@map("service_account_audit_log")
}

/// The lifecycle events recorded in ServiceAccountAuditLog (ADR-0048). MINT on create; ROTATE on a new
/// secret; REVOKE on soft delete; RESTORE on un-delete; PERMISSION_CHANGE when the grant set is edited.
enum ServiceAccountAuditAction {
  MINT
  ROTATE
  REVOKE
  RESTORE
  PERMISSION_CHANGE
}

/// Where an asset physically lives — office, datacenter, rack, warehouse or
/// "remote / with employee". Flat (non-hierarchical) for now.
/// See docs/02-domain/entities/location.md
model Location {
  id          String       @id @default(cuid())
  name        String
  type        LocationType
  description String?
  address     String?
  // String, not number: floors are labels like "PB", "Subsuelo 1", "Mezzanine".
  floor       String?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  assets Asset[]

  @@map("locations")
}

/// Classification of a Location. Hardcoded for now; user-managed custom types are
/// known, deferred debt — see docs/03-decisions/0017-location-type-enum.md and
/// the "Known debt" note in docs/02-domain/entities/location.md.
enum LocationType {
  OFFICE
  DATACENTER
  RACK
  REMOTE
  STORAGE
  OTHER
}

/// Classification for AssetModels (Laptop, Server, Switch, …). User-managed: created,
/// edited and soft-deleted from the app — the seed set is just an initial, non-special list.
/// See docs/02-domain/entities/asset-category.md
model AssetCategory {
  id          String    @id @default(cuid())
  // Unique among LIVE rows only: a PARTIAL unique index WHERE "deletedAt" IS NULL (raw SQL in the
  // migration — Prisma can't express it), so a soft-deleted category frees its name for reuse and
  // Restore can reclaim it. No `@unique` (that re-introduces the ghost-row collision). See ADR-0041.
  name        String
  description String?
  // Free string: a heroicon name for the web UI (e.g. "ServerStackIcon"). Not validated.
  icon        String?
  // ADVISORY specs dictionary (ADR-0007 amendment, #851): a declarative field list
  // (`{ key, label, type, required?, enumValues? }[]`) that drives hints + soft warnings for the
  // Asset.specs of this category's models — validated in the app (zod, @lazyit/shared), NEVER in the
  // DB and NEVER hard-blocking. Nullable/non-destructive: existing rows keep NULL = no governance.
  specsSchema Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  models AssetModel[]

  @@map("asset_categories")
}

/// The generic make/model an Asset is an instance of (e.g. "Dell Latitude 5520"). Holds
/// type-level facts; per-unit facts live on Asset. See docs/02-domain/entities/asset-model.md
model AssetModel {
  id           String         @id @default(cuid())
  name         String
  manufacturer String
  // Unique among LIVE rows when present (NULLs are distinct in Postgres): a PARTIAL unique index
  // WHERE "deletedAt" IS NULL (raw SQL in the migration). A soft-deleted model frees its sku for
  // reuse; Restore reclaims it. No `@unique` (that re-introduces the ghost collision). See ADR-0041.
  sku          String?
  description  String?
  // Model-level default specs (e.g. "Latitude 5520 ships with 16GB"). Distinct from Asset.specs.
  specs        Json?
  // Optional category; SetNull on delete so models survive (audit > strict integrity).
  categoryId   String?
  category     AssetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  assets Asset[]

  @@index([categoryId])
  @@map("asset_models")
}

/// The first-class citizen: a single tracked thing, a concrete instance of an AssetModel
/// living at a Location. See docs/02-domain/entities/asset.md and docs/02-domain/asset-centric.md
model Asset {
  id           String      @id @default(cuid())
  name         String
  // serial / assetTag: unique among LIVE rows when present (NULLs distinct in Postgres). Each gets a
  // PARTIAL unique index WHERE "deletedAt" IS NULL (raw SQL in the migration), so a soft-deleted asset
  // frees its serial/assetTag for reuse and Restore reclaims them. No `@unique` (ghost collision). ADR-0041.
  serial       String?
  assetTag     String?
  status       AssetStatus
  // Per-unit type-specific attributes (jsonb). Validated in the app (zod), not the DB.
  // See docs/03-decisions/0007-flexible-asset-specs-jsonb.md
  specs        Json?
  notes        String?
  // Optional GROUPING attribute (ADR-0076, #857): a Snipe-IT-style "Company" used to group/filter/
  // report assets. NOT a tenancy/scoping boundary — anyone with asset:read sees ALL assets regardless
  // of company (Modo B per-record scoping was decided against, #841). Free-text + autocomplete over
  // already-used values (no Company entity/table/CRUD).
  // ponytail: free-text column with a datalist of existing values — promote to a managed Company
  // entity ONLY if governance (rename / soft-delete / merge) is ever needed.
  company      String?
  purchaseDate DateTime?
  warrantyEnd  DateTime?
  // FKs are SetNull: deleting a Model/Location detaches assets, never deletes them.
  modelId      String?
  model        AssetModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)
  locationId   String?
  location     Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  assignments  AssetAssignment[]
  history      AssetHistory[]
  // KB links (ADR-0042): knowledge-base articles linked to this asset ("the runbook for THIS server").
  articleLinks ArticleLink[]
  // Infra topology (ADR-0070): nodes on the CMDB canvas backed by this asset (owner/KB/secrets/warranty
  // flow through here). SetNull on the node's assetId — deleting an asset detaches, never deletes, a node.
  infraNodes   InfraNode[]

  @@index([modelId])
  @@index([locationId])
  @@index([status])
  @@map("assets")
}

enum AssetStatus {
  OPERATIONAL
  IN_MAINTENANCE
  IN_STORAGE
  RETIRED
  LOST
  UNKNOWN
}

/// lazyit's FIRST instance-config entity (ADR-0063, #363): the org-wide, single-row, opt-in scheme
/// that auto-assigns a running asset tag on create. SINGLE ROW — the instance has exactly one scheme,
/// so the row IS the identity (the "small configuration, the row is the identity" spirit of
/// RolePermission, ADR-0046 §3). Singleton enforced two ways: the `id` defaults to the fixed literal
/// `"singleton"` (so every upsert targets the same row) AND a CHECK constraint in the migration pins
/// it to that value (so a second row is structurally impossible). The service reads/upserts by that id.
///
/// The running number is STRUCTURAL (ADR-0063 §1/§2): the rendered tag is always
/// `prefix + zeroPad(nextNumber, width) + suffix`, so `nextNumber` is an always-present column — there
/// is no template string / `{num}` token to omit. `nextNumber` is the MONOTONIC counter (the NEXT
/// value to allocate); it is incremented atomically via a single-row `{ increment: 1 }` that COMMITS
/// ON ITS OWN — deliberately OUTSIDE the asset-create `$transaction`. That independent commit is what
/// makes "gaps accepted" work and lets a tag collision ADVANCE rather than spin: were the increment
/// folded into the create transaction, a rolled-back insert would un-consume the number and a retry
/// would re-render the same colliding tag forever. Gaps are accepted (ADR-0063 §3): a rolled-back /
/// retried / deleted allocation is never back-filled.
///
/// Conventions (ADR-0006): MUTABLE instance config — `createdAt` + `updatedAt`, but NO `deletedAt`.
/// It is NOT soft-deletable (so it is deliberately absent from SOFT_DELETABLE_MODELS): disabling the
/// scheme flips `enabled` and leaves the counter where it was (re-enabling continues, never restarts).
model AssetTagScheme {
  /// Fixed singleton key — the only valid value is "singleton" (a migration CHECK pins it). Not a
  /// generated id: there is one config row for the whole instance, so its id is a known constant.
  id         String   @id @default("singleton")
  /// Optional free-text affix prepended to the rendered tag (e.g. "LAZY-"). null = none.
  prefix     String?
  /// Optional free-text affix appended to the rendered tag. null = none.
  suffix     String?
  /// Optional zero-pad width for the number (e.g. 5 => 00042). 0 / null = no padding.
  width      Int?
  /// The MONOTONIC counter — the NEXT sequence value to allocate. Incremented atomically (Prisma
  /// `{ increment: 1 }`) in a standalone update that COMMITS INDEPENDENTLY of the asset-create
  /// `$transaction`, so concurrent creates read distinct numbers and a rolled-back insert never
  /// un-consumes its number (gaps accepted; a collision advances instead of spinning). Edge cases
  /// (ADR-0063): the counter freezes with a clean 400 at the int4 ceiling (unreachable at any real
  /// scale), and a `startNumber: 0` makes the first rendered tag carry the number 0.
  nextNumber Int      @default(1)
  /// OFF by default (ADR-0063 §4): false = no auto-tag; the create path is byte-for-byte unchanged.
  enabled    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // No deletedAt: mutable instance config, never soft-deleted (ADR-0006 / ADR-0063 §1). Keep OUT of
  // SOFT_DELETABLE_MODELS so reads are not auto-scoped to `deletedAt: null` (the column doesn't exist).
  @@map("asset_tag_scheme")
}

/// Instance SMTP settings — the singleton config store for OUTBOUND EMAIL (issue #615, ADR-0079).
/// Same singleton pattern as AssetTagScheme (ADR-0063): ONE admin-only row (`settings:manage`), a
/// migration CHECK pins the id. Unlocks an email CHANNEL behind the notification bell (ADR-0056); a
/// curated set of operational nudges is emailed (via a BullMQ worker, ADR-0053) when `enabled` is on.
///
/// The password is a SERVER-MANAGED machine credential (the server MUST read it to authenticate to the
/// relay — the explicit inverse of the zero-knowledge Secret Manager, INV-10). It is encrypted at rest
/// as an AES-256-GCM envelope (the same {ciphertext,iv,authTag,keyVersion} shape as WorkflowSecret, but
/// under its OWN key axis `SMTP_SECRET_KEY` — "one key per subsystem", ADR-0054/0079). The envelope
/// columns are NEVER returned on the wire (write-only; the read shape exposes only "passwordSet").
model SmtpSettings {
  /// Fixed singleton key — the only valid value is "singleton" (a migration CHECK pins it). Not a
  /// generated id: there is one SMTP config row for the whole instance.
  id                 String   @id @default("singleton")
  /// Master switch for outbound email. false (default) = never email; the test action still works.
  enabled            Boolean  @default(false)
  /// SMTP relay hostname. null until configured.
  host               String?
  /// SMTP relay port (1–65535). null until configured.
  port               Int?
  /// Transport security mode: "none" | "starttls" | "tls" (validated by the shared SmtpSecurity enum).
  security           String   @default("starttls")
  /// SMTP auth username. null = open/unauthenticated relay (the api only sends `auth` when set).
  username           String?
  /// Encrypted password envelope (AES-256-GCM under SMTP_SECRET_KEY). All four are null when no
  /// password is stored. WRITE-ONLY: never returned on the wire (the read shape exposes only passwordSet).
  passwordCiphertext String?
  passwordIv         String?
  passwordAuthTag    String?
  passwordKeyVersion Int?
  /// Envelope From address (messages are sent from here). null until configured.
  fromAddress        String?
  /// Optional human display name for the From header (e.g. "lazyit").
  fromName           String?
  /// TLS cert verification. true (default, secure) rejects an unverifiable cert; false allows a
  /// self-signed cert on a self-hosted relay (opt-in insecurity).
  rejectUnauthorized Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // No deletedAt: mutable instance config, never soft-deleted (same posture as AssetTagScheme).
  @@map("smtp_settings")
}

/// Timestamped join recording who owns an Asset, over time (asset-centric ownership; ADR-0004).
/// Append-only with a release marker: rows are never deleted, only "closed" by setting
/// releasedAt (ADR-0006). Multi-owner: an asset may have several active assignments at once.
/// See docs/02-domain/entities/asset-assignment.md and docs/03-decisions/0019-asset-assignment-integrity.md
model AssetAssignment {
  id             String          @id @default(cuid())
  // Required FKs use Restrict: an Asset/User that has assignment history cannot be hard-deleted
  // (history is preserved). Contrast Asset.modelId/locationId (SetNull). See ADR-0019.
  assetId        String
  asset          Asset           @relation(fields: [assetId], references: [id], onDelete: Restrict)
  // @db.Uuid to match User.id (uuid). Same for the audit FKs below.
  userId         String          @db.Uuid
  user           User            @relation("AssignmentOwner", fields: [userId], references: [id], onDelete: Restrict)
  assignedAt     DateTime        @default(now())
  // null => active. Setting it ends the assignment without deleting the row (not a soft delete).
  releasedAt     DateTime?
  // Optional audit FKs — who assigned / released. SetNull: losing the actor never blocks
  // deleting them, and the assignment record itself survives.
  assignedById   String?         @db.Uuid
  assignedBy     User?           @relation("AssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  releasedById   String?         @db.Uuid
  releasedBy     User?           @relation("AssignmentReleasedBy", fields: [releasedById], references: [id], onDelete: SetNull)
  // Service-account actors (ADR-0048): set instead of the User actor when a SERVICE ACCOUNT assigned /
  // released. A DB CHECK enforces at-most-one of (assignedById, assignedBySaId) and likewise for
  // released. Plain String (cuid → text). SetNull.
  assignedBySaId String?
  assignedBySa   ServiceAccount? @relation("AssignmentAssignedBySa", fields: [assignedBySaId], references: [id], onDelete: SetNull)
  releasedBySaId String?
  releasedBySa   ServiceAccount? @relation("AssignmentReleasedBySa", fields: [releasedBySaId], references: [id], onDelete: SetNull)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // No deletedAt: this is a lifecycle join, not a soft-deletable entity (ADR-0006).
  // A partial UNIQUE INDEX (assetId, userId) WHERE releasedAt IS NULL — "at most one active
  // assignment per (asset, user)" — is added as raw SQL in the migration: Prisma can't express
  // a partial index. See ADR-0019 and docs/05-runbooks/prisma-migrations.md §3.
  @@index([assetId])
  @@index([userId])
  @@map("asset_assignments")
}

/// Append-only log of discrete state changes for an Asset (ADR-0006 / ADR-0033). Written by explicit
/// service calls (no interceptor), transactionally with the change. Rows are never updated or
/// deleted. See docs/02-domain/entities/asset-history.md
model AssetHistory {
  // autoincrement: a log/history table, never exposed externally (ADR-0005).
  id               Int                   @id @default(autoincrement())
  // Required FK with Restrict: an asset with history cannot be hard-deleted (history is preserved),
  // mirroring AssetAssignment. Soft delete (UPDATE deletedAt) bypasses it. See ADR-0019/0033.
  assetId          String
  asset            Asset                 @relation(fields: [assetId], references: [id], onDelete: Restrict)
  eventType        AssetHistoryEventType
  // Contextual data (e.g. { from, to } on STATUS_CHANGED, { userId } on ASSIGNED). Unvalidated jsonb.
  payload          Json?
  // Who caused the change — from the X-User-Id shim (ADR-0022). SetNull: losing the actor never
  // blocks deleting them and the log row survives. null = system/unknown. @db.Uuid to match User.id.
  performedById    String?               @db.Uuid
  performedBy      User?                 @relation("AssetHistoryActor", fields: [performedById], references: [id], onDelete: SetNull)
  // Service-account actor (ADR-0048): set instead of performedById when a SERVICE ACCOUNT caused the
  // change. A DB CHECK enforces at-most-one of (performedById, serviceAccountId) — never both. SetNull
  // so the log survives a (never-issued) hard delete of the account. Plain String (cuid → text).
  serviceAccountId String?
  serviceAccount   ServiceAccount?       @relation("AssetHistorySaActor", fields: [serviceAccountId], references: [id], onDelete: SetNull)
  createdAt        DateTime              @default(now())

  // No updatedAt / deletedAt: append-only (ADR-0006). (assetId, id) serves the per-asset timeline
  // query (filter by asset, order by id desc, cursor on id).
  @@index([assetId, id])
  @@map("asset_history")
}

/// The discrete asset events recorded in AssetHistory (ADR-0033). RESTORED is emitted by the asset
/// restore endpoint (POST /assets/:id/restore — ADR-0041), the counterpart of DELETED.
enum AssetHistoryEventType {
  CREATED
  STATUS_CHANGED
  ASSIGNED
  RELEASED
  LOCATION_CHANGED
  MODEL_CHANGED
  SPECS_CHANGED
  DELETED
  RESTORED
}

/// An append-only log of discrete lifecycle events for a User (DEBT-2, issue #185). The User entity's
/// own audit trail — the counterpart of AssetHistory for the asset, closing the gap where Users had no
/// queryable history (only fire-and-forget IdP write-back log lines). Append-only (ADR-0006): rows are
/// only ever INSERTed, never updated or deleted; `createdAt` only — no updatedAt / deletedAt. Emitted
/// transactionally with the write it records (ADR-0033 pattern). Feeds the `recent_activity` view's
/// fourth source (entityType "user"). See docs/02-domain/entities/user.md + ADR-0050.
model UserHistory {
  // autoincrement: a log/history table, never exposed externally (ADR-0005).
  id               Int                  @id @default(autoincrement())
  // Required FK with Restrict: a user with history cannot be hard-deleted (history is preserved),
  // mirroring AssetHistory.assetId. Soft delete (UPDATE deletedAt) bypasses it. @db.Uuid to match User.id.
  userId           String               @db.Uuid
  user             User                 @relation("UserHistorySubject", fields: [userId], references: [id], onDelete: Restrict)
  eventType        UserHistoryEventType
  // Contextual data (e.g. { from, to } on ROLE_CHANGED, { fields } on UPDATED). Unvalidated jsonb.
  payload          Json?
  // Who caused the change — the authenticated human actor (ADR-0022). SetNull: losing the actor never
  // blocks deleting them and the log row survives. null = system/unknown. @db.Uuid to match User.id.
  // NOTE: on a self-action (e.g. a JIT-provisioned user, or an admin editing themselves) performedById
  // may equal userId — that is fine; subject and actor are distinct relations to the same User.
  performedById    String?              @db.Uuid
  performedBy      User?                @relation("UserHistoryActor", fields: [performedById], references: [id], onDelete: SetNull)
  // Service-account actor (ADR-0048): set instead of performedById when a SERVICE ACCOUNT caused the
  // change. A DB CHECK enforces at-most-one of (performedById, serviceAccountId) — never both. SetNull
  // so the log survives a (never-issued) hard delete of the account. Plain String (cuid → text).
  serviceAccountId String?
  serviceAccount   ServiceAccount?      @relation("UserHistorySaActor", fields: [serviceAccountId], references: [id], onDelete: SetNull)
  createdAt        DateTime             @default(now())

  // No updatedAt / deletedAt: append-only (ADR-0006). (userId, id) serves the per-user timeline query
  // (filter by user, order by id desc). A second index on createdAt powers the recent_activity view.
  @@index([userId, id])
  @@index([createdAt])
  @@map("user_history")
}

/// The discrete user-lifecycle events recorded in UserHistory (DEBT-2, issue #185). CREATED on
/// provisioning, UPDATED on a name/email edit, ROLE_CHANGED on an RBAC role change (payload { from,
/// to }), MANAGER_CHANGED on a manager change (payload { from, to } — each side a user-id, an
/// external-name string, or null; ADR-0058), DELETED on offboard (soft delete), RESTORED on
/// re-onboard, PASSWORD_RESET_SENT when an IdP reset link is requested. Mirrors AssetHistoryEventType's
/// CREATED/UPDATED/DELETED/RESTORED set.
enum UserHistoryEventType {
  CREATED
  UPDATED
  ROLE_CHANGED
  MANAGER_CHANGED
  DELETED
  RESTORED
  PASSWORD_RESET_SENT
}

/// User-managed grouping for knowledge-base Articles, EVOLVED into a hierarchical Folder (ADR-0059
/// §1): a self-ref `parentId` (null = a root folder) makes the flat set the root level of a tree.
/// The model/table stay `ArticleCategory` / `article_categories` (the rename to Folder/folders is a
/// deliberate follow-up); Article.categoryId becomes the "one home folder per article" FK, unchanged
/// in shape. Created/edited/soft-deleted from the app; the seed set is an initial, non-special list.
/// NO access semantics here — ADR-0060 attaches the per-folder permission boundary later.
/// See docs/02-domain/entities/folder.md and docs/02-domain/entities/article-category.md
model ArticleCategory {
  id          String            @id @default(cuid())
  // Unique among LIVE rows only, scoped to the PARENT (ADR-0059 §1): a PARTIAL unique index on
  // (parentId, name) WHERE "deletedAt" IS NULL (raw SQL in the migration), so `Servers/Linux` and
  // `Workstations/Linux` coexist and a soft-deleted folder frees its name within its parent. No
  // `@unique` (that re-introduces the ghost-row collision). See ADR-0041.
  name        String
  description String?
  // Free string: a heroicon name for the web UI (e.g. "ServerStackIcon"). Not validated.
  icon        String?
  // Optional sort key for sidebar/listings (lower first); null sorts last.
  order       Int?
  // Self-ref parent folder (ADR-0059 §1): null = a ROOT folder. SetNull on delete is a hard-delete
  // safety net only — our delete is a SOFT delete (UPDATE deletedAt) which never fires the FK, and
  // the service refuses to soft-delete a folder with live child folders (no silent orphaning, 409).
  // A cycle (a folder being its own ancestor) is rejected by the service's DFS guard.
  parentId    String?
  parent      ArticleCategory?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ArticleCategory[] @relation("FolderTree")
  // Folder access control (ADR-0060 §3): null/absent = PUBLIC (any authenticated holder of
  // `article:read` — preserves the pre-0060 behaviour). A non-null jsonb value is an OR-combined list
  // of the CLOSED rule vocabulary (FolderAccessRulesSchema in @lazyit/shared): `users` / `role` /
  // `appGrant` / `assetAssignment`. NOT a per-article ACL — the rule attaches to the FOLDER (a bounded
  // named set) and articles inherit their home folder's rule (INV-9). Validated by zod at the DTO edge
  // (catalog-as-code, ADR-0007 discipline); the shape is a reviewable closed set, never free-form
  // policy. Evaluated DB-first at read time (EXISTS over the live AccessGrant/AssetAssignment joins for
  // the dynamic kinds), never materialised — so access follows offboarding automatically.
  accessRules Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  articles Article[]
  // Nav-only "symlink" placements: this folder also surfaces these articles (ADR-0059 §2).
  aliases  ArticleAlias[]

  // Speeds the per-parent child listing and the name-uniqueness/cycle walks.
  @@index([parentId])
  @@map("article_categories")
}

/// A knowledge-base document (markdown). Append-only versioning + asset/application linking
/// (ADR-0042); still no tags. DRAFT is author-private, PUBLISHED is team-visible; authorship/
/// visibility rules live in the service (ADR-0022). Content is indexed in search (ADR-0035).
/// See docs/02-domain/entities/article.md
model Article {
  id             String          @id @default(cuid())
  // Short, memorable, unique among LIVE rows. Format/length validated in @lazyit/shared (lowercase,
  // [a-z0-9-], <=60). UNIQUENESS is a PARTIAL unique index WHERE "deletedAt" IS NULL (raw SQL in the
  // migration), so a soft-deleted article frees its slug for reuse and Restore reclaims it. No
  // `@unique` (that re-introduces the ghost-row collision). See ADR-0041.
  slug           String
  title          String
  // Markdown body (Postgres text). Validated/sanitized in the app, not the DB.
  content        String
  // Short summary for listings (<=280). Optional.
  excerpt        String?
  status         ArticleStatus   @default(DRAFT)
  // Required category. Restrict: a category with articles can't be hard-deleted (DB safety net);
  // the API also refuses to soft-delete a category that still has live articles. See ADR-0021/0019.
  categoryId     String
  category       ArticleCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  // Author = the creator (X-User-Id shim today, JWT later — ADR-0022). @db.Uuid to match User.id.
  // Restrict: authorship is preserved (the user can still be soft-deleted, an UPDATE).
  authorId       String          @db.Uuid
  author         User            @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  // Who last edited; optional. SetNull so losing the user nulls the link but keeps the article.
  lastEditedById String?         @db.Uuid
  lastEditedBy   User?           @relation("ArticleLastEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  // Set on the first publish, never cleared (records "was published at least once"). See ADR-0021.
  publishedAt    DateTime?
  // Flexible extras (estimatedReadingTime, externalLinks, …). Unvalidated jsonb — same debt as
  // Asset.specs. See ADR-0007 and docs/02-domain/entities/article.md.
  metadata       Json?
  // Estimated reading time in whole minutes, derived from `content` (~200 words/min; min 1 for any
  // non-empty body, 0 only for an empty one). A MAINTAINED column: the service recomputes it on every
  // write that touches `content` (create/import/edit), so the LEAN list (ARTICLE_LIST_SELECT) can ship
  // a reading metric for the card UI WITHOUT loading the markdown body. Backfilled for existing rows in
  // the migration. See ADR-0042 and docs/02-domain/entities/article.md.
  readingMinutes Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  // Append-only edit history (ADR-0042): every create/edit snapshots a new ArticleVersion.
  versions      ArticleVersion[]
  // Article<->Asset/Application associations (ADR-0042): "the runbook for THIS server/app".
  links         ArticleLink[]
  // Nav-only "symlink" placements of THIS article into other folders (ADR-0059 §2). Cascade.
  aliases       ArticleAlias[]
  // Outgoing `[[slug]]` wiki-link edges authored in THIS article's body (ADR-0059 §3), hard-rebuilt
  // on every content-changing save. Cascade from the source.
  outgoingLinks ArticleWikiLink[] @relation("WikiLinkSource")
  // Incoming wiki-link edges whose RESOLVED target is this article (ADR-0059 §4) — the backlink
  // ("References") read. resolvedTargetId is SetNull on a hard delete of this article.
  incomingLinks ArticleWikiLink[] @relation("WikiLinkResolvedTarget")

  // (categoryId, status): per-category filtered listings. (status, publishedAt): "latest published".
  @@index([categoryId, status])
  @@index([status, publishedAt])
  @@map("articles")
}

/// Publication state of an Article. DRAFT = author-private; PUBLISHED = team-visible (ADR-0022).
enum ArticleStatus {
  DRAFT
  PUBLISHED
}

/// Append-only snapshot of an Article's editable state, written on every create/edit that changes
/// title/content/excerpt/status (ADR-0042). This restores the auditability principle (ADR-0006):
/// editing an article no longer destroys the prior body. Rows are NEVER updated, deleted or
/// soft-deleted — a pure log, like AssetHistory. `version` increments per article (1 on create).
/// See docs/02-domain/entities/article-version.md
model ArticleVersion {
  // autoincrement: an append-only history table, never exposed externally (ADR-0005), mirroring
  // AssetHistory. The externally meaningful key is (articleId, version), enforced unique below.
  id               Int             @id @default(autoincrement())
  // Required FK with Restrict: an article with version history cannot be hard-deleted (history is
  // preserved), mirroring AssetHistory/AssetAssignment. Soft delete (UPDATE deletedAt) bypasses it.
  articleId        String
  article          Article         @relation(fields: [articleId], references: [id], onDelete: Restrict)
  // Monotonic per-article revision number (1 on create, then 2, 3, …). Allocated in the same
  // transaction as the article write, so the snapshot can't drift from the article it describes.
  version          Int
  // Frozen copy of the article's editable state at this revision.
  title            String
  content          String
  excerpt          String?
  status           ArticleStatus
  // Who produced this revision (the editor / creator) — from the auth shim (ADR-0022). SetNull:
  // losing the actor never blocks deleting them and the log row survives. @db.Uuid to match User.id.
  editedById       String?         @db.Uuid
  editedBy         User?           @relation("ArticleVersionEditor", fields: [editedById], references: [id], onDelete: SetNull)
  // Service-account actor (ADR-0048): set instead of editedById when a SERVICE ACCOUNT produced the
  // revision. A DB CHECK enforces at-most-one of (editedById, serviceAccountId). Plain String. SetNull.
  serviceAccountId String?
  serviceAccount   ServiceAccount? @relation("ArticleVersionEditorSa", fields: [serviceAccountId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())

  // No updatedAt / deletedAt: append-only (ADR-0006). (articleId, version) is the natural unique key
  // and also serves the per-article version timeline query (filter by article, order by version).
  @@unique([articleId, version])
  @@map("article_versions")
}

/// Associates an Article with EITHER an Asset OR an Application — exactly one target (ADR-0042),
/// making the KB IT-native ("the runbook for THIS server / this app"). A pure association join (NOT
/// soft-deletable and NOT an audit log): add via POST, remove via DELETE. A DB CHECK enforces
/// exactly-one-target and partial unique indexes prevent duplicate links (raw SQL in the migration).
/// See docs/02-domain/entities/article-link.md
model ArticleLink {
  id               String          @id @default(cuid())
  // The linked article. Cascade: the link is meaningless without its article and carries no audit
  // value, so a (rare) hard-delete of the article removes its links. Articles normally soft-delete.
  articleId        String
  article          Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  // Exactly one of assetId / applicationId is set (enforced by a CHECK constraint in the migration).
  // Cascade on both targets for the same reason as the article side.
  assetId          String?
  asset            Asset?          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  applicationId    String?
  application      Application?    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  // Who created the link — from the auth shim (ADR-0022). SetNull: losing the actor never blocks
  // deleting them and the link survives. @db.Uuid to match User.id.
  createdById      String?         @db.Uuid
  createdBy        User?           @relation("ArticleLinkCreator", fields: [createdById], references: [id], onDelete: SetNull)
  // Service-account actor (ADR-0048): set instead of createdById when a SERVICE ACCOUNT created the
  // link. A DB CHECK enforces at-most-one of (createdById, serviceAccountId). Plain String. SetNull.
  serviceAccountId String?
  serviceAccount   ServiceAccount? @relation("ArticleLinkCreatorSa", fields: [serviceAccountId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())

  // No updatedAt / deletedAt: a link is current-state, created or removed (hard delete), never
  // edited or soft-deleted. Duplicate-link prevention is two PARTIAL unique indexes (one per target,
  // WHERE the target IS NOT NULL) added as raw SQL in the migration — Prisma can't express them.
  @@index([articleId])
  @@index([assetId])
  @@index([applicationId])
  @@map("article_links")
}

/// A nav-only "symlink" that makes one Article appear inside a Folder OTHER than its home, without
/// moving its home or widening its access (ADR-0059 §2). A pure current-state placement (NOT
/// soft-deletable and NOT an audit log): created via POST, removed via hard DELETE. No access
/// column — an alias is presentation only; ADR-0060 owns any future alias-as-share. A folder that
/// equals the article's home is rejected by the service. UNIQUE(folderId, articleId) — at most one
/// alias per placement. See docs/02-domain/entities/article-alias.md
model ArticleAlias {
  id        String          @id @default(cuid())
  // The folder this alias places the article into (NOT the home folder). Cascade: the alias is
  // meaningless without its folder and carries no audit value (the ArticleLink posture exactly).
  folderId  String
  folder    ArticleCategory @relation(fields: [folderId], references: [id], onDelete: Cascade)
  // The aliased article. Cascade for the same reason.
  articleId String
  article   Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  // No updatedAt / deletedAt: current-state, created or removed (hard delete), never soft-deleted
  // (ADR-0006). At most one alias per (folder, article).
  @@unique([folderId, articleId])
  @@index([articleId])
  @@map("article_aliases")
}

/// A materialized article↔article edge — one row per `[[slug]]` reference found in a source
/// Article's body (ADR-0059 §3/§4). Powers backlinks ("References") and fast resolution. A DERIVED
/// projection: hard-rebuilt on every content-changing save (delete-then-insert IN the article-write
/// transaction, alongside the version snapshot — so the edge can never drift from the body). Distinct
/// from ArticleLink (article↔asset/application). `targetSlug` is the source of truth; resolvedTargetId
/// is a best-effort CACHE of "the slug matched a live article at rebuild time", nullable (an
/// unresolved forward reference is render-time state, never an error). See
/// docs/02-domain/entities/article-wiki-link.md
model ArticleWikiLink {
  id               String   @id @default(cuid())
  // The article whose body contains this `[[slug]]`. Cascade: the edge is meaningless without its
  // source and carries no audit value. On a normal SOFT delete (UPDATE deletedAt) the FK never
  // fires; the rebuild-on-save pass and the soft-delete read filter keep backlinks honest.
  sourceArticleId  String
  source           Article  @relation("WikiLinkSource", fields: [sourceArticleId], references: [id], onDelete: Cascade)
  // The verbatim `[[slug]]` target text — the resolution key. Lowercase slug shape (parsed/normalized
  // in @lazyit/shared). Not an FK: an unresolved slug is allowed (a forward reference).
  targetSlug       String
  // The matched live article when the slug currently resolves, else null. SetNull is a HARD-delete
  // safety net (a normal soft delete leaves it stale — harmless, re-resolved on the next rebuild).
  resolvedTargetId String?
  resolvedTarget   Article? @relation("WikiLinkResolvedTarget", fields: [resolvedTargetId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  // No updatedAt / deletedAt: current-state, hard-rebuilt on save, never edited or soft-deleted
  // (ADR-0006). Indexed on the source (the rebuild's delete-by-source) and the resolved target (the
  // backlink lookup `WHERE resolvedTargetId = :id`).
  @@index([sourceArticleId])
  @@index([resolvedTargetId])
  @@map("article_wiki_links")
}

/// User-managed grouping for Applications (SaaS, Internal, Service, …). Like AssetCategory /
/// ArticleCategory: created, edited and soft-deleted from the app; the seed set is an initial,
/// non-special list. See docs/02-domain/entities/application-category.md
model ApplicationCategory {
  id          String    @id @default(cuid())
  // Unique among LIVE rows only: a PARTIAL unique index WHERE "deletedAt" IS NULL (raw SQL in the
  // migration). A soft-deleted category frees its name for reuse; Restore reclaims it. No `@unique`
  // (that re-introduces the ghost-row collision). See ADR-0041.
  name        String
  description String?
  // Free string: a heroicon name for the web UI (e.g. "CloudIcon"). Not validated.
  icon        String?
  // Optional sort key for sidebar/listings (lower first); null sorts last.
  order       Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  applications Application[]

  @@map("application_categories")
}

/// Something a User can be granted access to: a SaaS product (Jira, GitHub, AWS), an internal
/// system, or a technical service (VPN, AD group). The catalog of access targets. See ADR-0023
/// and docs/02-domain/entities/application.md
model Application {
  id          String               @id @default(cuid())
  name        String
  description String?
  // The system's URL (console/login). Optional, not validated as a URL at the DB level.
  url         String?
  // The vendor / provider (Atlassian, Microsoft, AWS, …). Optional.
  vendor      String?
  // Optional category; SetNull on delete so applications survive (audit > strict integrity),
  // like AssetModel -> AssetCategory. See ADR-0023.
  categoryId  String?
  category    ApplicationCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  // Flags an application whose access is especially sensitive (production infra, finance, …).
  isCritical  Boolean              @default(false)
  // Flexible extras (ssoProvider, ownerTeam, externalIds, …). Unvalidated jsonb — same debt as
  // Asset.specs / Article.metadata. See ADR-0007 and ADR-0023.
  metadata    Json?
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?

  grants       AccessGrant[]
  // KB links (ADR-0042): knowledge-base articles linked to this application ("the runbook for THIS app").
  articleLinks ArticleLink[]

  // Applications Workflow Engine (ADR-0054, epic #248). An application MAY own workflows that
  // provision/deprovision access in its external system; with none enabled it behaves exactly as
  // today (the opt-in default). Per-app integration config + the engine's own encrypted secrets
  // also hang here. All FKs are Restrict (an app with workflow history can't be hard-deleted; soft
  // delete bypasses) — see WorkflowRun.applicationId is denormalized for cheap per-app reporting.
  workflows           ApplicationWorkflow[]
  workflowConnections WorkflowConnection[]
  workflowRuns        WorkflowRun[]
  workflowSecrets     WorkflowSecret[]

  @@index([categoryId])
  @@map("applications")
}

/// Timestamped join recording that a User has access to an Application, over time (ADR-0023).
/// Append-only with a revoke marker: rows are never deleted, only "closed" by setting revokedAt
/// (ADR-0006). Multi-grant: a user may hold several active grants on one app at different
/// accessLevels — there is deliberately NO uniqueness constraint (contrast AssetAssignment).
/// The actor (grantedById / revokedById) comes from the X-User-Id shim (ADR-0022 / ADR-0023).
/// See docs/02-domain/entities/access-grant.md
model AccessGrant {
  id            String          @id @default(cuid())
  // Required FKs use Restrict: a User / Application with grant history cannot be hard-deleted
  // (history is preserved). Soft delete (UPDATE deletedAt) bypasses this — see ADR-0023.
  // @db.Uuid to match User.id (uuid); same for the audit FKs below.
  userId        String          @db.Uuid
  user          User            @relation("AccessGrantUser", fields: [userId], references: [id], onDelete: Restrict)
  applicationId String
  application   Application     @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  // Free-form, app-defined (e.g. "admin", "developer", "viewer"); lazyit never interprets it.
  accessLevel   String?
  grantedAt     DateTime        @default(now())
  // null => active. Setting it ends the grant without deleting the row (not a soft delete).
  revokedAt     DateTime?
  // null => no expiry. A periodic sweeper auto-revokes a grant once it passes expiresAt, through the
  // normal revoke() path (deprovision workflow + system attribution fire) — ADR-0023 (amended).
  expiresAt     DateTime?
  // Optional audit FKs — who granted / revoked. SetNull: losing the actor never blocks deleting
  // them, and the grant record survives. null => system / unknown.
  grantedById   String?         @db.Uuid
  grantedBy     User?           @relation("AccessGrantGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
  revokedById   String?         @db.Uuid
  revokedBy     User?           @relation("AccessGrantRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)
  // Service-account actors (ADR-0048): set instead of the User actor when a SERVICE ACCOUNT granted /
  // revoked. A DB CHECK enforces at-most-one of (grantedById, grantedBySaId) and likewise for revoked.
  // Plain String (cuid → text). SetNull.
  grantedBySaId String?
  grantedBySa   ServiceAccount? @relation("AccessGrantGrantedBySa", fields: [grantedBySaId], references: [id], onDelete: SetNull)
  revokedBySaId String?
  revokedBySa   ServiceAccount? @relation("AccessGrantRevokedBySa", fields: [revokedBySaId], references: [id], onDelete: SetNull)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Applications Workflow Engine (ADR-0054, epic #248). The provisioning/deprovisioning runs this
  // grant triggered (WorkflowRun.accessGrantId). Restrict on that side: a grant with run history
  // can't be hard-deleted (grants are append-only anyway). The engine fires AFTER this grant's tx
  // commits and NEVER rolls it back — the deliberate inverse of the Zitadel strong-coupling.
  workflowRuns WorkflowRun[]

  // No deletedAt: a lifecycle join, not a soft-deletable entity (ADR-0006). No uniqueness
  // constraint — multi-grant is allowed by design (ADR-0023).
  @@index([userId])
  @@index([applicationId])
  @@map("access_grants")
}

/// User-managed grouping for Consumables (Cables, Adapters, Peripherals, …). Like AssetCategory /
/// ApplicationCategory: created, edited and soft-deleted from the app; the seed set is an initial,
/// non-special list. See docs/02-domain/entities/consumable-category.md
model ConsumableCategory {
  id          String    @id @default(cuid())
  // Unique among LIVE rows only: a PARTIAL unique index WHERE "deletedAt" IS NULL (raw SQL in the
  // migration). A soft-deleted category frees its name for reuse; Restore reclaims it. No `@unique`
  // (that re-introduces the ghost-row collision). See ADR-0041.
  name        String
  description String?
  // Free string: a heroicon name for the web UI (e.g. "CpuChipIcon"). Not validated.
  icon        String?
  // Optional sort key for sidebar/listings (lower first); null sorts last.
  order       Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  consumables Consumable[]

  @@map("consumable_categories")
}

/// A stock-counted supply item (cables, adapters, toner, …). Distinct from Asset, which is tracked
/// individually (ADR-0008). `currentStock` is a cache maintained transactionally by movements
/// (ADR-0034). See docs/02-domain/entities/consumable.md
model Consumable {
  id           String              @id @default(cuid())
  name         String
  // Unique among LIVE rows when present (NULLs are distinct in Postgres): a PARTIAL unique index
  // WHERE "deletedAt" IS NULL (raw SQL in the migration). A soft-deleted consumable frees its sku for
  // reuse; Restore reclaims it. No `@unique` (that re-introduces the ghost collision). See ADR-0041.
  sku          String?
  // Optional category; SetNull on delete so consumables survive (deleting a category detaches them).
  categoryId   String?
  category     ConsumableCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description  String?
  // Cached on-hand quantity, maintained transactionally by ConsumableMovement (ADR-0034). Never
  // edited directly — only through movements.
  currentStock Int                 @default(0)
  // Optional reorder threshold for low-stock alerts (currentStock <= minStock).
  minStock     Int?
  // Free-form unit of measure ("units", "meters", "boxes", …). Not an enum on purpose.
  unit         String              @default("units")
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?

  movements ConsumableMovement[]

  @@index([categoryId])
  @@map("consumables")
}

/// Append-only ledger of stock changes for a Consumable (ADR-0034). Each row adjusts the cached
/// `Consumable.currentStock` transactionally. Rows are never updated or deleted.
/// See docs/02-domain/entities/consumable-movement.md
model ConsumableMovement {
  // autoincrement: a log/history table, never exposed externally (ADR-0005).
  id               Int                    @id @default(autoincrement())
  // Required FK with Restrict: a consumable with movement history cannot be hard-deleted.
  consumableId     String
  consumable       Consumable             @relation(fields: [consumableId], references: [id], onDelete: Restrict)
  type             ConsumableMovementType
  // Always positive. IN adds, OUT subtracts (409 if it would go negative), ADJUSTMENT sets
  // currentStock to this value (an absolute recount). See ADR-0034.
  quantity         Int
  reason           String?
  // Who performed it — from the X-User-Id shim (ADR-0022). SetNull. @db.Uuid to match User.id.
  performedById    String?                @db.Uuid
  performedBy      User?                  @relation("ConsumableMovementActor", fields: [performedById], references: [id], onDelete: SetNull)
  // Service-account actor (ADR-0048): set instead of performedById when a SERVICE ACCOUNT performed the
  // movement. A DB CHECK enforces at-most-one of (performedById, serviceAccountId). Plain String. SetNull.
  serviceAccountId String?
  serviceAccount   ServiceAccount?        @relation("ConsumableMovementSaActor", fields: [serviceAccountId], references: [id], onDelete: SetNull)
  notes            String?
  createdAt        DateTime               @default(now())

  // No updatedAt / deletedAt: append-only (ADR-0006). (consumableId, id) serves the ledger query.
  @@index([consumableId, id])
  @@map("consumable_movements")
}

/// Stock movement direction (ADR-0034).
enum ConsumableMovementType {
  IN
  OUT
  ADJUSTMENT
}

// ─────────────────────────────────────────────────────────────────────────────────────────────
// VIEW: recent_activity (ADR-0043) — NOT a Prisma model.
//
// A read-only Postgres VIEW that UNION ALLs the FIVE append-only activity sources (AssetHistory,
// AssetAssignment assigned/released, AccessGrant granted/revoked, ConsumableMovement stock in/out/
// adjustment, and — DEBT-2 / issue #185 — UserHistory user lifecycle) into one normalized, newest-
// first stream for the dashboard's recent-activity feed.
// Columns: { occurredAt timestamptz, actorId uuid?, entityType text, entityId text, action text,
// summary text }. Prisma cannot express a UNION view in PSL, so it lives ONLY as raw SQL — created in
// prisma/migrations/20260601163936_recent_activity_view/migration.sql and REPLACED (CREATE OR REPLACE)
// to add the UserHistory branch in prisma/migrations/<ts>_recent_activity_view_user/migration.sql (the
// same "SQL Prisma can't represent" pattern as the partial unique indexes — see
// docs/05-runbooks/prisma-migrations.md §3).
// Prisma neither emits nor flags it as drift; it is read with a typed $queryRaw in DashboardService.
// The contract lives in @lazyit/shared (schemas/recent-activity.ts). Documented here so the view is
// discoverable from the schema. See docs/02-domain/entities/recent-activity.md.
// ─────────────────────────────────────────────────────────────────────────────────────────────

// ═════════════════════════════════════════════════════════════════════════════════════════════
// APPLICATIONS WORKFLOW ENGINE (ADR-0054, epic #248) — Phase 1a: data-model foundation ONLY.
//
// An Application MAY OPT IN to workflows that provision/deprovision a user in its EXTERNAL system
// when access changes inside lazyit. The load-bearing default is opt-in: an application with no
// enabled workflow behaves EXACTLY as today (ADR-0023) — granting access just records the
// AccessGrant, one indexed lookup of overhead, nothing fires.
//
// THE DECOUPLING INVARIANT (the deliberate inverse of the Zitadel strong-coupling, ADR-0043/INV-5):
// the engine fires AFTER the AccessGrant transaction commits, NEVER inside it. A failing external
// call never rolls back, blocks or 503s the grant. The grant is the source of truth; provisioning
// is an eventually-consistent downstream effect surfaced as a FAILED run + notification.
//
// SUBSTRATE (ADR-0053): "BullMQ executes, Postgres remembers." These tables ARE the durable system
// of record (run state, the pinned version, idempotency keys, the audit ledger); BullMQ/Valkey only
// carries `{ workflowRunId }` jobs. A Valkey flush is a reconcile, not data loss.
//
// SCOPE: this block is DATA MODEL only — no engine runtime, routes, services or connectors land
// until Phase 1b. v1 connectors = REST + WEBHOOK_OUT + MANUAL (public destinations only); SDK / MCP
// / PREBUILT / CUSTOM and the timer triggers are reserved enum slots with NO behavior.
// ═════════════════════════════════════════════════════════════════════════════════════════════

/// What access-lifecycle event starts a workflow (ADR-0054). v1 builds the two AccessGrant-derived
/// triggers; the timer-based ones are RESERVED slots (no behavior in Phase 1a) so adding them later
/// never forces a schema/enum migration mid-flight.
enum WorkflowTrigger {
  // v1 — fired AFTER an AccessGrant is created / revoked (one event per grant, incl. batchRevoke).
  ACCESS_GRANTED
  ACCESS_REVOKED
  // RESERVED (Phase 3, no behavior yet): N days after a grant; cron-like periodic; periodic
  // "is this access still valid?" → bounded to re-run + report (NEVER an IGA/attestation subsystem).
  TIMER_AFTER_GRANT
  SCHEDULED
  RECERTIFICATION
}

/// Multi-grant deprovision semantics for an ACCESS_REVOKED workflow (ADR-0054, CEO Q1). Because a
/// user may hold several active grants on one app (ADR-0023, no uniqueness), revoking ONE grant must
/// not always cut external access. The enforcement is Phase 1b; this is just the policy field.
enum WorkflowDeprovisionPolicy {
  // DEFAULT, safer: deprovision externally only when the LAST active grant for that user+app is
  // revoked — never cuts off a user who still holds legitimate access.
  LAST_ACTIVE_GRANT
  // Deprovision on every revoke (one run per grant acts independently).
  EACH_GRANT
}

/// The connector kind discriminator for a WorkflowConnection (ADR-0054). v1 ships REST + WEBHOOK_OUT
/// + MANUAL; SDK / MCP / PREBUILT / CUSTOM are RESERVED slots (no executor in Phase 1a) so the model
/// never needs a migration when they land. The per-kind `config` shape is a zod discriminated union
/// in @lazyit/shared (ADR-0007), validated at the edge — never per-kind tables.
enum WorkflowConnectionKind {
  // v1 — declarative, zero code per app: any HTTP API (the Jira case), a signed outbound webhook,
  // or a human task (no external call).
  REST
  WEBHOOK_OUT
  MANUAL
  // RESERVED (later phases, no behavior): vendor SDK, MCP tool target, curated prebuilt connector,
  // bespoke in-image connector. Code-backed tiers are shipped IN THE IMAGE, never runtime-loaded.
  SDK
  MCP
  PREBUILT
  CUSTOM
}

/// The run-level state machine (ADR-0054). One row per fired event walks this set. AWAITING_INPUT is
/// the load-bearing pause state: NO BullMQ job is in flight (a manual step / inbound callback parks
/// the run in Postgres, the worker is freed, resume is an event) — which is why a multi-day human
/// wait costs one row, not a worker, and why we do not need Temporal.
enum WorkflowRunStatus {
  PENDING // created (the durable outbox row written in the grant tx), not yet picked up.
  RUNNING // a worker is advancing a step.
  AWAITING_INPUT // paused on a manual step / inbound callback — no job in flight.
  SUCCEEDED // terminal — all steps done.
  FAILED // terminal — a step failed terminally (the grant is NEVER touched).
  COMPENSATED // terminal — saga rollback of already-applied EXTERNAL effects ran (never the grant).
}

/// The per-attempt status of a WorkflowStepRun (ADR-0054). Append-only: one row per attempt, so the
/// "current" state of a step is the latest row for (runId, stepKey). A retry is a NEW row.
enum WorkflowStepRunStatus {
  SUCCEEDED
  FAILED
  AWAITING_INPUT // this attempt suspended the run for a human / callback.
  SKIPPED // the effectively-once guard short-circuited (a prior attempt already SUCCEEDED).
  COMPENSATED // this row records a compensation (saga rollback) of the step's external effect.
}

/// The lifecycle of a ManualTask (ADR-0054). Mutable lifecycle entity: COMPLETED / CANCELLED are
/// STATUSES, not a soft delete — so it carries NO deletedAt.
enum ManualTaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

/// The opt-in binding "application X automates trigger T" (ADR-0054). Mutable config, soft-delete
/// (ADR-0006/0041): edited, disabled and restorable. The "is this app automated for this trigger?"
/// lookup the grant path does — cached so the opt-in default stays one indexed read. The active
/// definition is the LATEST WorkflowVersion for this workflow (no denormalized pointer in v1, which
/// avoids a circular FK); a run snapshots and PINS the version it executed.
model ApplicationWorkflow {
  id                         String                    @id @default(cuid())
  // Required FK with Restrict: an app with workflow history can't be hard-deleted (soft delete
  // bypasses), mirroring AccessGrant. cuid (text) FK — Application.id is cuid.
  applicationId              String
  application                Application               @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  trigger                    WorkflowTrigger
  // Admin label + optional description.
  name                       String
  description                String?
  // A disabled workflow never fires (the grant path still does nothing extra). Default off so a
  // freshly-created/draft workflow is inert until explicitly enabled.
  enabled                    Boolean                   @default(false)
  // Multi-grant deprovision policy (CEO Q1). Default LAST_ACTIVE_GRANT (safer). Enforcement: Phase 1b.
  deprovisionPolicy          WorkflowDeprovisionPolicy @default(LAST_ACTIVE_GRANT)
  // The dedicated least-privilege ServiceAccount the engine EXECUTES this workflow AS (ADR-0048).
  // SetNull: losing the SA never blocks deletion; never a fabricated human, never ADMIN. The chosen
  // SA is copied onto each run (WorkflowRun.executedAsServiceAccountId) so a run's principal is
  // pinned even if this changes later.
  executedAsServiceAccountId String?
  executedAsServiceAccount   ServiceAccount?           @relation("ApplicationWorkflowEngineSa", fields: [executedAsServiceAccountId], references: [id], onDelete: SetNull)
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  deletedAt                  DateTime?

  versions WorkflowVersion[]
  runs     WorkflowRun[]

  // At most ONE LIVE workflow per (applicationId, trigger) — a deterministic "the engine fires the
  // workflow that matches" rule. A PARTIAL unique index WHERE "deletedAt" IS NULL (raw SQL in the
  // migration; Prisma can't express it), so a soft-deleted binding frees the slot for reuse/replace
  // (ADR-0041). No `@@unique` here (that re-introduces the ghost-row collision).
  @@index([applicationId])
  @@index([executedAsServiceAccountId])
  @@map("application_workflows")
}

/// The per-application integration config — the connector INSTANCE (ADR-0054). Mutable config,
/// soft-delete. Credentials are NEVER inlined: `secretId` references the engine's own encrypted
/// store (WorkflowSecret). The per-kind `config` shape is zod-validated jsonb in @lazyit/shared
/// (ADR-0007) — non-secret connection settings only (base URL, auth SCHEME, header names, …).
model WorkflowConnection {
  id            String                 @id @default(cuid())
  // Per-app credentials/config; one connection is reused by the app's grant + revoke workflows.
  applicationId String
  application   Application            @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  kind          WorkflowConnectionKind
  // Admin label for the connection.
  name          String
  // Non-secret, zod-validated-per-kind connection config (ADR-0007). NEVER a cleartext credential.
  config        Json
  // The credential this connection authenticates with — a REFERENCE into WorkflowSecret, never the
  // secret itself (INV-6). SetNull: losing the secret row never deletes the connection (it surfaces
  // as "no credential configured"). Rotation = point this at a new WorkflowSecret.
  secretId      String?
  secret        WorkflowSecret?        @relation("ConnectionCredential", fields: [secretId], references: [id], onDelete: SetNull)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  deletedAt     DateTime?

  // Inverse of WorkflowSecret.connection ("SecretConnectionScope") — secrets scoped to THIS
  // connection (a secret may also be app-level, with a null connectionId).
  scopedSecrets WorkflowSecret[] @relation("SecretConnectionScope")

  @@index([applicationId])
  @@index([secretId])
  @@map("workflow_connections")
}

/// The immutable, replayable definition snapshot (ADR-0054) — the ArticleVersion precedent (ADR-0042).
/// Every edit APPENDS a new version; a WorkflowRun PINS the `workflowVersionId` it executed so editing
/// a definition never corrupts an in-flight or paused run. The step graph is embedded as zod-validated
/// jsonb `steps` (a discriminated union keyed on the step kind, ADR-0007) — atomically snapshot-able
/// as one unit; a WorkflowStep is a LOGICAL node inside the jsonb, not a v1 table.
model WorkflowVersion {
  // autoincrement: an append-only definition table, never exposed externally (ADR-0005). The
  // externally meaningful key is (workflowId, version), enforced unique below.
  id            Int                 @id @default(autoincrement())
  // Required FK with Restrict: a workflow with version history can't be hard-deleted (soft delete
  // bypasses), mirroring ArticleVersion → Article.
  workflowId    String
  workflow      ApplicationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  // Monotonic per-workflow revision number (1, 2, 3, …) — the human handle ("v3").
  version       Int
  // The frozen step graph: a zod-validated discriminated list (ADR-0007). Immutable.
  steps         Json
  // Who authored this version (ADR-0048): human XOR service account, at-most-one CHECK in the
  // migration. SetNull both; @db.Uuid for the User FK (User.id is uuid).
  createdById   String?             @db.Uuid
  createdBy     User?               @relation("WorkflowVersionAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdBySaId String?
  createdBySa   ServiceAccount?     @relation("WorkflowVersionAuthorSa", fields: [createdBySaId], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())

  runs WorkflowRun[]

  // No updatedAt / deletedAt: append-only (ADR-0006). (workflowId, version) is the natural unique key
  // and also serves the per-workflow version timeline query.
  @@unique([workflowId, version])
  @@map("workflow_versions")
}

/// The execution ledger — one row per fired event (ADR-0054). Append-only WITH lifecycle markers
/// (the AccessGrant precedent): never deleted, identity immutable, but `status` + timestamps
/// transition during execution. The unique `idempotencyKey` ("<trigger>:<accessGrantId>") yields AT
/// MOST ONE run per grant event; retries live INSIDE a run as WorkflowStepRun.attempt rows. The run
/// is the idempotency unit; the step is the retry unit.
model WorkflowRun {
  id                         String              @id @default(cuid())
  // The definition + the EXACT version executed (replay/audit). Restrict on both (history-bearing).
  workflowId                 String
  workflow                   ApplicationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  workflowVersionId          Int
  workflowVersion            WorkflowVersion     @relation(fields: [workflowVersionId], references: [id], onDelete: Restrict)
  // Denormalized for cheap "runs for this app" reporting (the dashboard/per-app history). Restrict.
  applicationId              String
  application                Application         @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  trigger                    WorkflowTrigger
  // The source event for ACCESS_GRANTED / ACCESS_REVOKED. Nullable for a future pure SCHEDULED run.
  // Restrict: a grant with run history isn't hard-deleted (grants are append-only anyway).
  accessGrantId              String?
  accessGrant                AccessGrant?        @relation(fields: [accessGrantId], references: [id], onDelete: Restrict)
  // The dedup key, UNIQUE (full unique — this table has no soft delete, so no ghost-row concern).
  // "<trigger>:<accessGrantId>:<replaySeq>" (ADR-0057): the natural grant run is seq 0, each manual
  // replay-latest increments the suffix → exactly one run per (grant event, replay). Existing pre-0057
  // rows are backfilled to the `:0` form in the migration so the format is uniform.
  idempotencyKey             String              @unique
  // The replay sequence within (trigger, accessGrantId) — 0 for the organic grant-derived run, N for the
  // Nth manual clone-to-new-run (ADR-0057 Option 3). Part of `idempotencyKey`; surfaced for the lineage.
  replaySeq                  Int                 @default(0)
  // Lineage (ADR-0057): the parent run a replay-latest cloned FROM. Self-FK, nullable, SetNull (losing the
  // parent never blocks a hard delete and the clone's own ledger survives). Null for an organic grant run.
  supersedesRunId            String?
  supersedesRun              WorkflowRun?        @relation("WorkflowRunReplayLineage", fields: [supersedesRunId], references: [id], onDelete: SetNull)
  replayedBy                 WorkflowRun[]       @relation("WorkflowRunReplayLineage")
  status                     WorkflowRunStatus   @default(PENDING)
  // THE CAUSE (ADR-0048): inherited from the grant's actor — the human XOR service account who
  // granted/revoked. at-most-one CHECK in the migration. SetNull both; @db.Uuid for the User FK.
  triggeredById              String?             @db.Uuid
  triggeredBy                User?               @relation("WorkflowRunTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)
  triggeredBySaId            String?
  triggeredBySa              ServiceAccount?     @relation("WorkflowRunTriggeredBySa", fields: [triggeredBySaId], references: [id], onDelete: SetNull)
  // THE PRINCIPAL THE RUN ACTS AS for any lazyit-side audited effect — the engine's own SA (ADR-0048),
  // pinned from ApplicationWorkflow at run creation. SetNull. NOT part of the at-most-one CHECK (it
  // is a separate axis from the triggering actor).
  executedAsServiceAccountId String?
  executedAsServiceAccount   ServiceAccount?     @relation("WorkflowRunExecutedAsSa", fields: [executedAsServiceAccountId], references: [id], onDelete: SetNull)
  startedAt                  DateTime?
  finishedAt                 DateTime?
  // REDACTED failure summary (error class + step key) — NEVER bodies/secrets/PII (INV-6, ADR-0031).
  error                      Json?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  steps       WorkflowStepRun[]
  manualTasks ManualTask[]

  // No deletedAt: an append-only ledger (ADR-0006). Indexes for the per-app/-workflow history reads
  // and the operator "failed runs" view; accessGrantId for the reconcile/de-dup path.
  @@index([applicationId])
  @@index([workflowId])
  @@index([accessGrantId])
  @@index([status])
  @@map("workflow_runs")
}

/// The per-attempt execution log (ADR-0054) — strictly append-only, the AssetHistory precedent: one
/// immutable row per step ATTEMPT. A retry is a NEW row with attempt+1; the current state of a step
/// is the latest row for (runId, stepKey). This is the audit trail and report source — it is never
/// updated or deleted, only appended.
model WorkflowStepRun {
  // autoincrement: a child execution log, never an external handle (ADR-0005).
  id                    Int                   @id @default(autoincrement())
  // Restrict on the parent run (history-bearing; the run is itself append-only and never hard-deleted).
  runId                 String
  run                   WorkflowRun           @relation(fields: [runId], references: [id], onDelete: Restrict)
  // The step's position in the pinned version's step list, and its stable node key within that jsonb.
  stepIndex             Int
  stepKey               String
  // 1-based; a retry is a new row with attempt+1.
  attempt               Int
  status                WorkflowStepRunStatus
  // The captured EXTERNAL id (e.g. the created Jira user id) so a later revoke deprovisions the EXACT
  // account this run created — the correlation that makes provisioning effectively-once.
  externalCorrelationId String?
  // REDACTED outcome metadata ONLY (HTTP status, duration, error class, mapped field NAMES) — NEVER
  // request/response bodies, credentials or mapped PII values (INV-6, ADR-0031).
  metadata              Json?
  createdAt             DateTime              @default(now())

  // No updatedAt / deletedAt: append-only (ADR-0006). (runId, id) serves the per-run step timeline.
  @@index([runId, id])
  // The orchestrator's hot idempotency/attempt lookups (#594): the retry idempotency guard filters by
  // (runId, stepKey, attempt) and nextAttemptFor orders (runId, stepKey) by attempt desc — this covers
  // both so neither falls back to scanning the run's rows under the (runId, id) prefix.
  @@index([runId, stepKey, attempt])
  @@map("workflow_step_runs")
}

/// Human-in-the-loop step (ADR-0054) — a mutable LIFECYCLE entity, NO soft-delete: COMPLETED /
/// CANCELLED are statuses, not a deletedAt. Created when a run hits a MANUAL step (or onError:manual);
/// surfaced through the notification bell/SSE inbox; completion (with typed input) re-enqueues the
/// run. The typed input SCHEMA lives in the pinned version's step config (referenced by stepKey) —
/// completion validates the human's `input` against it as untrusted data (ADR-0054 §scope: v1 = typed
/// input + STATIC suggestions only; role/team/manager/AD are a FUTURE model-first ADR, NOT here).
model ManualTask {
  id              String           @id @default(cuid())
  // Restrict on the parent run (the run carries the timeline; runs are append-only).
  runId           String
  run             WorkflowRun      @relation(fields: [runId], references: [id], onDelete: Restrict)
  // The suspended step's stable node key within the pinned version (where the input schema is defined).
  stepKey         String
  // Optional direct assignee (SetNull; @db.Uuid). When null, the task is offered to a COHORT.
  assigneeId      String?          @db.Uuid
  assignee        User?            @relation("ManualTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  // Optional cohort the task is offered to (e.g. a role/team label). Completion requires
  // `workflow:task` AND an assignee/cohort match — permission alone is the IDOR trap (enforced 1b).
  cohort          String?
  // What the human must do/answer.
  prompt          String
  // The value(s) the human provided, fed back into the run on completion. Validated by zod against
  // the step's expected shape; MAY contain PII → treated as sensitive, never logged (INV-6).
  input           Json?
  status          ManualTaskStatus @default(PENDING)
  // Who resolved it (ADR-0048): human XOR service account, at-most-one CHECK in the migration.
  completedById   String?          @db.Uuid
  completedBy     User?            @relation("ManualTaskCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  completedBySaId String?
  completedBySa   ServiceAccount?  @relation("ManualTaskCompletedBySa", fields: [completedBySaId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // No deletedAt: status (COMPLETED/CANCELLED) is the lifecycle (ADR-0006). Indexes for the inbox.
  @@index([runId])
  @@index([assigneeId, status])
  @@index([status])
  @@map("manual_tasks")
}

/// The engine's OWN encrypted credential store (ADR-0054). Mutable config, soft-delete. AES-256-GCM
/// at rest: the ciphertext + per-value random IV + GCM auth tag + the key version are stored; the
/// CLEARTEXT is NEVER persisted and never returned by any read (INV-6). The encryption SERVICE is
/// Phase 1b — this is the at-rest column shape only. (Decision: the engine brings its own store
/// rather than coupling to the Settings/SystemSecret store; one key axis per subsystem.)
model WorkflowSecret {
  id            String              @id @default(cuid())
  // Scope: every secret belongs to an application (Restrict — a secret's app can't be hard-deleted).
  applicationId String
  application   Application         @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  // Optional connection scope: the connection this credential was provisioned for. SetNull; null =
  // an app-level secret not yet bound to a specific connection. (Named distinctly from the
  // connection's own `secretId` credential reference — see WorkflowConnection.)
  connectionId  String?
  connection    WorkflowConnection? @relation("SecretConnectionScope", fields: [connectionId], references: [id], onDelete: SetNull)
  // Human-recognizable, NON-secret label (e.g. "Jira API token").
  label         String
  // AES-256-GCM envelope (at-rest only; never cleartext). base64/hex text columns for portability.
  ciphertext    String
  iv            String
  authTag       String
  // Which encryption key produced this envelope — supports key rotation without re-reading plaintext.
  keyVersion    Int                 @default(1)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?

  // Inverse of WorkflowConnection.secret ("ConnectionCredential") — connections currently USING
  // this secret as their credential.
  connectionsUsing WorkflowConnection[] @relation("ConnectionCredential")

  @@index([applicationId])
  @@index([connectionId])
  @@map("workflow_secrets")
}

/// In-app notification bell (ADR-0056) — an APPEND-ONLY event store of curated operational nudges an
/// admin should glance at. One immutable row per logical event (createdAt only — NO updatedAt /
/// deletedAt, per ADR-0006: the AssetHistory / AccessGrant immutable-event precedent). Read state is a
/// SEPARATE per-admin join (`NotificationRead`), computed fan-out-on-READ — so storage is proportional
/// to EVENTS, not events × admins, and the audience is always current.
///
/// Notifications are operational nudges, NOT the audit system-of-record — the append-only history
/// tables and ledgers remain that. The bell is allowed to FORGET: a 90-day retention sweep
/// (NotificationsRetentionSweeper) prunes old rows + their read joins. Anything in `metadata` is
/// REDACTED (names/ids only, never bodies/secrets/PII — INV-6, ADR-0031).
///
/// `entityType` + `entityId` are a SOFT, polymorphic deep-link target (the app / user / consumable /
/// workflow run the nudge is about) — deliberately NOT a hard FK: the bell must be free to forget and
/// to point at heterogeneous entities, exactly like the `recent_activity` view's text `entityId`.
/// `targetUserId` IS a real (optional, SetNull) FK to the person the nudge is about, for a secondary
/// click-through that survives the user's deletion.
///
/// `recipientUserId` (ADR-0056 amendment 2026-06-14, issue #453) is the SECOND visibility axis — who
/// SEES this notification, distinct from `targetUserId` (who it is ABOUT). `null` = a BROADCAST to every
/// `notification:read` holder (the v1 admin feed, unchanged); a uuid = a TARGETED nudge visible to THAT
/// user in their own bell, even when they hold no `notification:read`. Same FK shape as `targetUserId`
/// (optional, SetNull, @db.Uuid): losing the recipient never blocks deletion and the event survives.
model Notification {
  id              String   @id @default(cuid())
  // The closed catalog type (NotificationType in @lazyit/shared) — drives the bell's icon + copy.
  // Plain String, mirroring RolePermission.permission: the closed catalog lives as zod in shared, so
  // adding a type never needs an enum migration.
  type            String
  // Presentation severity ramp (info | warning | critical) — a render cue, not a business criticality.
  severity        String   @default("info")
  // The dedupe key — `<type>:<entityId>` (+ a coarse time bucket for low_stock). Makes emitters
  // IDEMPOTENT: a retry / a flapping consumable / a re-fired listener collapses to ONE row per logical
  // event (ADR-0056 §4). UNIQUE — full unique (this table has no soft delete, so no ghost-row concern).
  dedupeKey       String   @unique
  // Soft, polymorphic deep-link target (NOT a FK — see model doc). null entityType ⇒ no click-through.
  entityType      String?
  entityId        String?
  // The person the nudge is ABOUT (grantee / elevated user). Optional FK, SetNull: losing the user
  // never blocks deletion and the event survives. @db.Uuid to match User.id.
  targetUserId    String?  @db.Uuid
  targetUser      User?    @relation("NotificationTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  // Who SEES it (ADR-0056 amendment, #453): null = broadcast to every `notification:read` holder; a
  // uuid = TARGETED to that user's own bell (even a non-admin). Optional FK, @db.Uuid to match User.id.
  // onDelete: CASCADE (NOT SetNull like targetUserId) — issue #470: a TARGETED notification whose
  // recipient is hard-deleted has no audience, so it must be DROPPED, not silently promoted into the
  // broadcast set (recipientUserId=null) visible to every `notification:read` holder. Hard-deleting a
  // user is rare (only the just-created-user rollback paths), so this is defense-in-depth.
  recipientUserId String?  @db.Uuid
  recipientUser   User?    @relation("NotificationRecipientUser", fields: [recipientUserId], references: [id], onDelete: Cascade)
  // Server-built human headline + an optional one-line clarifier.
  title           String
  summary         String?
  // REDACTED extra context the web may render (names/ids only — never bodies/secrets/PII; INV-6).
  metadata        Json?
  createdAt       DateTime @default(now())

  // The per-admin read joins for this event (fan-out-on-read). Restrict on that side: an event with
  // read history is not hard-deletable by a stray cascade — the retention sweep is the ONLY deleter,
  // and it removes the read joins FIRST, then the event.
  reads NotificationRead[]

  // No updatedAt / deletedAt: append-only (ADR-0006). Indexes: the dedupe key (idempotent emit),
  // (type, createdAt) / createdAt for the newest-first feed + the retention sweep's age scan, and
  // recipientUserId for the per-user targeted-feed scan (ADR-0056 amendment, #453).
  @@index([type, createdAt])
  @@index([createdAt])
  @@index([recipientUserId])
  @@map("notifications")
}

/// The per-admin READ join for a Notification (ADR-0056 §1) — fan-out-on-read. One row written LAZILY
/// the first time an admin marks a notification read; its ABSENCE = unread for that admin. `readAt` is
/// the only mutable field (an idempotent mark-read upsert touches it). Unread-for-admin-A = a
/// Notification with no NotificationRead row for A (subject to retention); unread COUNT is one anti-join
/// over the small admin cohort.
model NotificationRead {
  // autoincrement: a join row, never exposed externally (ADR-0005).
  id             Int          @id @default(autoincrement())
  // The event this read state is for. Restrict: the retention sweep deletes these joins explicitly
  // before the event, so a notification with read history is never silently cascaded away.
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Restrict)
  // The admin who read it. Cascade: losing a user drops ONLY that user's read rows (never the event).
  // @db.Uuid to match User.id.
  userId         String       @db.Uuid
  user           User         @relation("NotificationReader", fields: [userId], references: [id], onDelete: Cascade)
  // When the admin marked it read (the lazy first mark; idempotent re-marks keep the original).
  readAt         DateTime     @default(now())

  // One read row per (notification, admin) — the upsert target + the anti-join's uniqueness guarantee.
  @@unique([notificationId, userId])
  // Per-admin unread anti-join scans by user; per-notification cleanup scans by notification.
  @@index([userId])
  @@map("notification_reads")
}

// =====================================================================================================
// Secret Manager — zero-knowledge vaults (ADR-0061, crypto design note, #366 / sub-issue #421).
//
// The DELIBERATE crypto-model INVERSE of WorkflowSecret: WorkflowSecret is server-decryptable by design
// (a connector authenticates at run time → reveal() + WORKFLOW_SECRET_KEY exist); the Secret Manager is
// NEVER server-decryptable. The server stores ONLY public material, wrapped blobs, and ciphertext — it
// holds NO key over any value (INV-10). There is no server-side reveal() and no env master key over
// values; decryption is entirely client-side. NEVER log/return a value, a private key (wrapped or not),
// a DEK (wrapped or not), a vault passphrase, or a recovery key (ADR-0031, crypto note §8).
//
// SLICE 2a (#421) = data foundation ONLY: these tables, the migration (incl. the two raw-SQL partial
// unique indexes), the soft-delete registration, and the shared DTOs. NO controllers/services/endpoints/
// authz — those are slice 2b.
// =====================================================================================================

/// A folder vault — the CRYPTO BOUNDARY of the Secret Manager (ADR-0061 §2). Each vault owns a single
/// random DEK under which every SecretItem in it is encrypted; the DEK is NEVER stored in clear — the
/// only copies that exist are the per-member VaultMembership rows (the DEK wrapped to each member's
/// public key). The server sees only the non-secret `name` and the member list — it can NEVER decrypt
/// the vault (INV-10). NO folder FK in v1: the KB↔Secret link is purely the §8 chip handle
/// ({{ lazyit_secret.HANDLE }}), resolved render-time, not a DB FK. Mutable domain entity → cuid() +
/// soft delete (ADR-0005/0006). Vault-name uniqueness is a LIVE-only PARTIAL unique index `WHERE
/// "deletedAt" IS NULL` (raw SQL in the migration — Prisma can't express it; never a PSL @unique, which
/// would re-introduce the ghost-row collision — ADR-0041). See docs/02-domain/entities/secret-vault.md.
model SecretVault {
  id   String @id @default(cuid())
  // Server-visible, NON-secret name (metadata — left of the §9 zero-knowledge line). Global uniqueness
  // among LIVE rows is the raw-SQL partial unique index in the migration (NOT @unique here).
  name String

  // The encrypted values stored under this vault's DEK. onDelete Restrict on the item side: a vault
  // with items cannot be hard-purged (history/ciphertext is preserved). Vaults normally soft-delete.
  items                     SecretItem[]
  // One row per crypto member, each carrying the DEK wrapped to that member's public key. onDelete
  // Cascade on the membership side: a membership is a current-state join, meaningless without its vault.
  memberships               VaultMembership[]
  // Service-account crypto members (ADR-0080): the same wrapped-DEK join keyed to a ServiceAccount, so a
  // headless caller can retrieve this vault's ciphertext. Same Cascade semantics as `memberships`.
  serviceAccountMemberships ServiceAccountVaultMembership[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("secret_vaults")
}

/// A single secret VALUE inside a SecretVault (ADR-0061 §2, crypto note §3) — a password, API key, or
/// note. It stores ONLY the ciphertext of the value, encrypted under the vault DEK, in columns that
/// MIRROR WorkflowSecret byte-for-byte: ciphertext / iv / authTag / keyVersion (base64 text, at-rest
/// only, never on a wire-read that the SERVER decrypts, never logged). The decisive difference from
/// WorkflowSecret: the key that decrypts these columns is the DEK, which the server never holds in clear
/// — so there is NO server-side reveal(); decryption is client-side under the unwrapped vault DEK
/// (INV-10). `handle` is the §8 chip reference (machine token, e.g. {{ lazyit_secret.HANDLE }}); `label`
/// is the human display title — both are server-visible metadata, never the value. Mutable domain entity
/// → cuid() + soft delete (ADR-0005/0006). `handle` is GLOBALLY unique among LIVE rows via a raw-SQL
/// PARTIAL unique index `WHERE "deletedAt" IS NULL` (the §8 chip must resolve to exactly one item — the
/// deliberate contract for slice 4; never a PSL @unique). See docs/02-domain/entities/secret-item.md.
model SecretItem {
  id         String         @id @default(cuid())
  // Scope: every item belongs to a vault. Restrict — a vault with items can't be hard-purged (matches
  // WorkflowSecret.applicationId Restrict). Vaults soft-delete (UPDATE deletedAt), which bypasses the FK.
  vaultId    String
  vault      SecretVault    @relation(fields: [vaultId], references: [id], onDelete: Restrict)
  // The §8 KB-chip reference ({{ lazyit_secret.HANDLE }}) — server-visible metadata, never the value.
  // GLOBALLY unique among LIVE rows via the raw-SQL partial unique index in the migration (NOT @unique).
  handle     String
  // Human-recognizable display title (e.g. "Production DB root password") — server-visible, never value.
  label      String
  // AES-256-GCM envelope of the value under the vault DEK (at-rest only; never cleartext; never logged).
  // base64 text columns — mirrors WorkflowSecret EXACTLY (ciphertext excludes the 16-byte tag; authTag
  // holds the trailing 16 bytes; iv is the 12-byte nonce). The client splits the @noble/ciphers gcm()
  // output into ciphertext + authTag on write and re-concatenates on read (crypto note §3).
  ciphertext String
  iv         String
  authTag    String
  // Which DEK VERSION produced this envelope (crypto note §3). Unlike WorkflowSecret (server env-key
  // version), here it tracks the per-vault DEK version. v1 writes 1 and never rotates; it is the
  // forward-compat seam for the deferred hard-revoke / DEK-rotation (ADR-0061 §5, Phase 2).
  keyVersion Int            @default(1)
  // The STRUCTURAL TYPE of this secret (ADR-0075) — server-visible METADATA only, same trust class as
  // `handle`/`label`, NEVER the value. It tells the UI which typed form/icon/renderer to use WITHOUT
  // decrypting: the typed payload (e.g. an SSH key's {privateKey, publicKey}) is a CLIENT-SIDE JSON
  // encoding serialized into the SAME opaque `ciphertext` blob — the server never sees its contents
  // (INV-10 unchanged). GENERIC = a legacy/plain string value (the back-compat default for all existing
  // rows and any create that omits `kind`). Additive: no crypto path or envelope shape changes.
  kind       SecretItemKind @default(GENERIC)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?

  @@index([vaultId])
  @@map("secret_items")
}

/// The structural TYPE of a SecretItem value (ADR-0075). METADATA only — it never describes the
/// plaintext, only how the CLIENT should serialize/encrypt and later render/parse the value. GENERIC is a
/// plain string (legacy + default); the others carry a client-side JSON payload inside the same opaque
/// ciphertext. The server stores the enum and is otherwise blind to the payload (INV-10).
enum SecretItemKind {
  GENERIC
  SSH_KEY
  TOTP
  CERTIFICATE
}

/// Records that a User is a CRYPTO MEMBER of a SecretVault (ADR-0061 §4, crypto note §2). The row's
/// load-bearing payload is the vault DEK WRAPPED to that member's public key (ECIES-style over X25519:
/// ephemeralPublicKey + wrapNonce + wrappedDek) — the only form in which a copy of the DEK exists. The
/// server stores the wrapped blob and can NEVER unwrap it. Granting = wrapping the existing DEK to a new
/// member's public key, which requires the granter to ALREADY be able to unwrap it ("no
/// grant-what-you-can't-read" — the crypto twin of INV-9). A CURRENT-STATE JOIN (like ArticleLink):
/// cuid(), createdAt + updatedAt (the wrapped blob is RE-WRITTEN on a peer-reset, §6). NO `deletedAt` —
/// v1 revoke is a HARD DROP of the row (the wrapped-DEK copy ceases to exist); not soft-deletable. The
/// (vaultId, userId) uniqueness is a PLAIN PSL @@unique precisely because there is no soft-delete to work
/// around (no ghost rows). See docs/02-domain/entities/vault-membership.md.
model VaultMembership {
  id                 String      @id @default(cuid())
  // The vault this membership grants crypto access to. Cascade: a wrapped-DEK copy is a current-state
  // join, meaningless without its vault — a (rare) hard-delete of the vault drops its memberships.
  vaultId            String
  vault              SecretVault @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  // The member. FK → the uuid User. Cascade: a wrapped-DEK copy is meaningless without its owner, so a
  // hard-delete of the user drops it. @db.Uuid to match User.id.
  userId             String      @db.Uuid
  user               User        @relation("VaultMembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  // The wrapped-DEK blob (crypto note §2). ephemeralPublicKey/wrapNonce/wrappedDek are base64 text; none
  // discloses the DEK without the member's private key. The server stores them in clear (they are
  // public/ciphertext, left of the §9 line) and NEVER unwraps them.
  ephemeralPublicKey String
  wrapNonce          String
  wrappedDek         String
  // Which wrap VERSION produced this blob — forward-compat seam mirroring SecretItem.keyVersion.
  wrapVersion        Int         @default(1)
  createdAt          DateTime    @default(now())
  // Re-wrap on peer-reset (§6): a surviving member re-wraps the DEK to the member's NEW public key,
  // updating this row in place — hence updatedAt. NO deletedAt: v1 revoke HARD-DROPs the row.
  updatedAt          DateTime    @updatedAt

  // At most one membership per (vault, member). A PLAIN @@unique (not a partial index): this row HARD-
  // deletes, so there is no soft-delete ghost row to exclude — the full unique index is correct here.
  @@unique([vaultId, userId])
  @@index([userId])
  @@map("vault_memberships")
}

/// One keypair per User (1:1 with the uuid User) — the identity the Secret Manager wraps vault DEKs TO
/// (ADR-0061 §3, crypto note §2/§4). The `publicKey` is stored in CLEAR (it is public — anyone may wrap
/// a DEK to it; that is how granting works). The X25519 private key is NEVER stored raw — only TWO
/// independent AES-256-GCM-wrapped copies exist, so loss of one unlock path is survivable: copy A under
/// Argon2id(vault passphrase) — the first Argon2 path in the repo — and copy B under the recovery key
/// (HKDF; the recovery key is high-entropy random, shown ONCE, never persisted/logged in clear). The
/// vault passphrase is a Secret-Manager unlock secret, DISTINCT from the OIDC login password (lazyit
/// never receives the login credential). The server holds public material + wrapped blobs only, NEVER a
/// plaintext private key, passphrase, or recovery key (INV-10). Mutable domain entity → cuid() + soft
/// delete (ADR-0005/0006); a peer-reset replaces the keypair in place. See
/// docs/02-domain/entities/user-keypair.md.
model UserKeypair {
  id                        String    @id @default(cuid())
  // 1:1 with the uuid User. Cascade: the keypair is meaningless without its user, so a hard-delete of
  // the user drops it. @unique enforces the 1:1 (there is no soft-delete-reuse concern: one user → one
  // live keypair; a peer-reset REPLACES the row in place rather than minting a second). @db.Uuid to
  // match User.id.
  userId                    String    @unique @db.Uuid
  user                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // The X25519 public key (base64, 32 raw bytes) — the ONLY clear column. DEKs are wrapped to it.
  publicKey                 String
  // Copy A — private key wrapped under Argon2id(vault passphrase). The wrapped blob + its KDF inputs.
  // `kdfParams` records { alg, m, t, p, v } so a future Argon2 parameter bump is detectable/recoverable
  // (crypto note §4). All base64 text except kdfParams (jsonb). NEVER the unwrapped private key.
  privateKeyEncByPassphrase String
  passphraseSalt            String
  passphraseIv              String
  kdfParams                 Json
  // Copy B — private key wrapped under the recovery key (HKDF). The wrapped blob + its HKDF salt + IV.
  // The recovery key itself is shown ONCE client-side and NEVER stored (only this wrapped copy exists).
  privateKeyEncByRecovery   String
  recoverySalt              String
  recoveryIv                String
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  deletedAt                 DateTime?

  @@map("user_keypairs")
}

/// One keypair per ServiceAccount (1:1 with the cuid ServiceAccount) — the X25519 identity a headless
/// caller uses to be a crypto member of a vault (ADR-0080, extends ADR-0061 §3 + ADR-0048). The MACHINE
/// twin of UserKeypair, kept in a SEPARATE model (not a user/SA union) because a service account is a
/// SEPARATE principal, never a User. `publicKey` is stored in CLEAR (DEKs are wrapped to it). The X25519
/// private key is wrapped ONCE — under `Argon2id(SA token secret)` (the token plays the role the human
/// vault passphrase plays) — so ONLY `privateKeyEnc` + `privateKeySalt` + `privateKeyIv` + `kdfParams`
/// exist; there is NO recovery copy (the token is the only credential; loss = rotate, a documented
/// follow-up). The server holds public material + the wrapped blob ONLY, NEVER the token plaintext (only
/// its SHA-256 hash on ServiceAccount.tokenHash), NEVER the unwrapped private key, and NEVER the derived
/// KEK — the derivation + unwrap run CLIENT-SIDE in the CLI (INV-10). Mutable → cuid + soft delete; a
/// key rotation replaces the row in place. See docs/03-decisions/0080-service-account-secret-retrieval.md.
model ServiceAccountKeypair {
  id               String         @id @default(cuid())
  // 1:1 with the cuid ServiceAccount. Cascade: the keypair is meaningless without its account. @unique
  // enforces the 1:1 (one account → one live keypair; a rotation REPLACES the row in place via upsert,
  // never a second) — same discipline as UserKeypair.userId.
  serviceAccountId String         @unique
  serviceAccount   ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)
  // The X25519 public key (base64, 32 raw bytes) — the ONLY clear column. DEKs are wrapped to it.
  publicKey        String
  // The X25519 private key wrapped under `Argon2id(SA token secret)`: the wrapped blob + its KDF inputs.
  // All base64 text except kdfParams (jsonb). NEVER the unwrapped private key, NEVER the token.
  privateKeyEnc    String
  privateKeySalt   String
  privateKeyIv     String
  kdfParams        Json
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  @@map("service_account_keypairs")
}

/// Records that a ServiceAccount is a CRYPTO MEMBER of a SecretVault, carrying the vault DEK WRAPPED to
/// that account's public key (ADR-0080, extends ADR-0061 §4). The MACHINE twin of VaultMembership, keyed
/// to the cuid ServiceAccount (not the uuid User) so the human zero-knowledge tables stay untouched and
/// there is no nullable union. Granting = a HUMAN member re-wraps the DEK (which they can already unwrap)
/// to the SA's public key ("no grant-what-you-can't-read" still holds). The server stores the wrapped blob
/// and can NEVER unwrap it (INV-10). A CURRENT-STATE JOIN: createdAt + updatedAt (re-wrap on key rotation),
/// NO deletedAt — revoke HARD-DROPs the row. See docs/03-decisions/0080-service-account-secret-retrieval.md.
model ServiceAccountVaultMembership {
  id                 String         @id @default(cuid())
  // The vault this membership grants crypto access to. Cascade: a wrapped-DEK copy is meaningless
  // without its vault.
  vaultId            String
  vault              SecretVault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  // The service-account member. Cascade: a wrapped-DEK copy is meaningless without its account.
  serviceAccountId   String
  serviceAccount     ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)
  // The wrapped-DEK blob (ADR-0061 §2). base64 text; none discloses the DEK without the SA's private key.
  ephemeralPublicKey String
  wrapNonce          String
  wrappedDek         String
  wrapVersion        Int            @default(1)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  // At most one membership per (vault, service account). A PLAIN @@unique (not a partial index): this row
  // HARD-deletes on revoke, so there is no soft-delete ghost row to exclude.
  @@unique([vaultId, serviceAccountId])
  @@index([serviceAccountId])
  @@map("service_account_vault_memberships")
}

/// The discrete actions recorded in SecretAuditLog (ADR-0061 §10). Metadata-only: these name WHO acted
/// on WHICH vault/item/target — NEVER a secret value, key, or blob.
enum SecretAuditAction {
  VAULT_CREATED
  VAULT_DELETED
  ITEM_CREATED
  ITEM_UPDATED
  ITEM_DELETED
  MEMBERSHIP_GRANTED
  MEMBERSHIP_REVOKED
  KEYPAIR_CREATED
  KEYPAIR_RESET
  // Re-wrap of ONLY the password wrap (Copy A) on an existing keypair (ADR-0066, change/reset password):
  // publicKey + the recovery wrap (privateKeyEncByRecovery/recoverySalt/recoveryIv) are untouched, only
  // privateKeyEncByPassphrase/passphraseSalt/passphraseIv/kdfParams are replaced.
  PASSWORD_CHANGED
  // DORMANT (ADR-0066): the ADR-0065 "regenerate the recovery key with the password" flow was reverted.
  // The code that wrote this value is removed; the enum value is LEFT in place because dropping a Postgres
  // enum value requires a risky type recreation (not worth it for an unused, harmless value). No row uses it.
  RECOVERY_KEY_REGENERATED
  // Plaintext (or re-encrypted) export of a vault's secrets (#612). Decryption happens CLIENT-SIDE after
  // the member unlocks the vault (INV-10: the server never sees plaintext); this row records ONLY that an
  // export occurred — WHO exported WHICH vault, when, and an optional non-secret item count. NEVER a value.
  ITEMS_EXPORTED
  // A human bootstrapped a SERVICE ACCOUNT's keypair (ADR-0080): actorId = the ADMIN, targetServiceAccountId
  // = the SA. Records the crypto identity creation; the wrapped blob is never recorded, only that it happened.
  SA_KEYPAIR_CREATED
  // A SERVICE ACCOUNT programmatically fetched a vault's ciphertext over the headless endpoint (ADR-0080):
  // serviceAccountId = the SA actor (actorId is null — a bot is never a human), vaultId = the vault. The
  // decryption happens CLIENT-SIDE in the CLI (INV-10); this row records ONLY that a fetch occurred.
  ITEMS_FETCHED
  // A HUMAN member REVEALED a single item's value in the UI (#870): actorId = the member, vaultId = the
  // vault, itemId = the item. Distinct from ITEMS_FETCHED (machine/whole-vault, no itemId — ADR-0080).
  // The decrypt happens CLIENT-SIDE (INV-10); this row records ONLY that a per-item reveal occurred — WHO
  // revealed WHICH item, when. NEVER the plaintext, ciphertext, DEK, or wrapped key.
  ITEM_REVEALED
}

/// An APPEND-ONLY audit log of Secret Manager actions (ADR-0061 §10, crypto note §8) — records WHO acted
/// on WHICH vault/item, METADATA ONLY: NEVER a secret value, a key (wrapped or unwrapped), a DEK, a
/// passphrase, or a recovery key. Append-only (ADR-0006): rows are only ever INSERTed — autoincrement id
/// (a log table, never exposed externally — ADR-0005), `createdAt` ONLY, no updatedAt/deletedAt.
/// `actorId` is the only FK (→ uuid User, SetNull — the metadata row survives the actor's deletion;
/// null = system/unknown). `vaultId`/`itemId`/`targetUserId`/`serviceAccountId`/`targetServiceAccountId`
/// are PLAIN STRING columns with NO FK on purpose: the audit trail must survive even if the vault/item/
/// target/service-account is later removed (the notification-bell soft-target precedent). See
/// docs/02-domain/entities/secret-vault.md.
model SecretAuditLog {
  // autoincrement: a log table, never exposed externally (ADR-0005).
  id                     Int               @id @default(autoincrement())
  action                 SecretAuditAction
  // Who acted — the authenticated human actor (ADR-0022). SetNull: losing the actor never blocks
  // deleting them and the log row survives. null = system/unknown. @db.Uuid to match User.id.
  actorId                String?           @db.Uuid
  actor                  User?             @relation("SecretAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  // The SERVICE-ACCOUNT ACTOR (ADR-0048 fork #4 pattern, ADR-0080): set instead of actorId when a bot
  // acted (ITEMS_FETCHED). A SOFT REF (cuid, NO FK) — this log table already treats every non-human ref
  // as a soft ref (survives the SA's removal). A raw-SQL CHECK enforces at most one actor (human XOR SA).
  serviceAccountId       String?
  // Soft metadata references (NO FK) — the row must survive even if the vault/item/target is removed.
  vaultId                String?
  itemId                 String?
  targetUserId           String?
  // The SERVICE-ACCOUNT TARGET (ADR-0080): set on SA_KEYPAIR_CREATED and on a MEMBERSHIP_GRANTED/REVOKED
  // whose subject is an SA (targetUserId stays null then). A soft ref (cuid, NO FK) like the others.
  targetServiceAccountId String?
  createdAt              DateTime          @default(now())

  // No updatedAt / deletedAt: append-only (ADR-0006). Indexes: the per-vault audit timeline, the SA-actor
  // programmatic-read timeline (ITEMS_FETCHED — partly serves #870), and the newest-first / retention scan.
  @@index([vaultId])
  @@index([serviceAccountId])
  @@index([createdAt])
  @@map("secret_audit_logs")
}

/// Migrator import — the stateful wizard session (ADR-0069 wave 1, #627). TRANSIENT: deliberately
/// EXCLUDED from `SOFT_DELETABLE_MODELS` (soft-delete.extension.ts) and hard-deleted by a GC sweep on
/// `expiresAt` (the sweeper is a later wave). cuid id (operator-facing in the wizard URL — ADR-0005),
/// owner-scoped (no IDOR — ADR-0069 §11). `mapping`/`resolutionPlan` are the confirmed mapping and
/// frozen resolution-plan blobs (jsonb; @lazyit/shared zod wire shapes). The raw file is parsed once
/// and discarded — only the coerced rows persist, under TTL. See docs/03-decisions/0069-migrator-import.md.
model ImportSession {
  id             String              @id @default(cuid())
  entity         ImportEntity
  status         ImportSessionStatus @default(PENDING)
  // The human operator who started the import (ADR-0022). Restrict: do not orphan an in-flight import
  // by deleting its owner; the session is short-lived and GC-swept anyway. @db.Uuid to match User.id.
  ownerId        String              @db.Uuid
  owner          User                @relation("ImportSessionOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  // Confirmed column/value/FK mapping blob (ImportMappingSchema) — null until the map step.
  mapping        Json?
  // Frozen per-conflict resolution plan (ImportResolutionPlanSchema) — null until the dry-run step.
  resolutionPlan Json?
  // Detected source shape from the parse step (wave 2, #629): { headers, dialect, encoding, rowCount }.
  // Null until PARSED; lets the map step render columns without re-reading the (discarded) file.
  detected       Json?
  // Session-level failure detail when status is FAILED (e.g. a malformed file) — PII-free (§11). A
  // ROW-level error lives on ImportRow.error; this is the whole-file error that prevented any rows.
  error          Json?
  // SHA-256 of the uploaded file (never its contents) for the audit/idempotency correlation (§9).
  fileHash       String?
  expiresAt      DateTime
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // ImportRow cascade-deletes with the session (transient scratch). ImportRun does NOT — it is the
  // append-only audit ledger and survives session GC (it correlates back via the durable `sessionId`
  // plain column, not an FK), so there is no `runs` back-relation here. See the ImportRun model doc.
  rows ImportRow[]

  @@index([ownerId])
  @@index([expiresAt])
  @@map("import_sessions")
}

/// Migrator import — one parsed-and-coerced source row (ADR-0069 wave 1, #627). TRANSIENT: EXCLUDED
/// from `SOFT_DELETABLE_MODELS`, hard-deleted with its session. autoincrement id (thousands per
/// session, never exposed externally — ADR-0005). `raw` is the parsed source values; `coerced` is the
/// pre-pass output that feeds the unchanged CreateAssetSchema. `rowIndex` is the stable 0-based source
/// index the row-keyed result schema keys on. Carries `updatedAt` because a row's status mutates
/// across the wizard (PENDING→COERCED→VALID/INVALID→COMMITTED/...).
model ImportRow {
  id        Int             @id @default(autoincrement())
  sessionId String
  session   ImportSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  rowIndex  Int
  status    ImportRowStatus @default(PENDING)
  // Parsed source values (column → string) and the coercion-pre-pass output (field → coerced value).
  raw       Json
  coerced   Json?
  // Field-level / row error detail when status is INVALID/FAILED (PII-free in logs — §11).
  error     Json?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([sessionId, rowIndex])
  @@index([sessionId, status])
  @@map("import_rows")
}

/// Migrator import — the APPEND-ONLY audit ledger of a commit (ADR-0069 §9, #627). Records who/what/
/// when, the counts and conflict summary, and the file HASH (never contents) for audit + a future undo
/// correlation id. Append-only (ADR-0006): autoincrement id, `createdAt` ONLY — no updatedAt/deletedAt.
/// `sessionId` is a DURABLE PLAIN STRING — deliberately NOT an FK to ImportSession: the session is
/// transient (24h TTL, GC-hard-deleted) but this ledger must SURVIVE that deletion (ADR-0006: an
/// append-only ledger is never deleted). A cascading FK would let the session GC reap the ledger, so the
/// correlation is kept as a retained value (the asset→import correlation also rides the CREATED-event
/// `sessionId` provenance — ADR-0069 §8/§9). `actorId` is SetNull so the ledger survives the actor's
/// deletion. NOT in `SOFT_DELETABLE_MODELS`.
model ImportRun {
  id              Int          @id @default(autoincrement())
  // Durable correlation to the originating session. NOT an FK (see model doc): the value is retained
  // after the session row is GC-deleted, so the ledger outlives its transient session.
  sessionId       String
  entity          ImportEntity
  // Who ran the commit (ADR-0022). SetNull: the audit row survives the actor's deletion. @db.Uuid.
  actorId         String?      @db.Uuid
  actor           User?        @relation("ImportRunActor", fields: [actorId], references: [id], onDelete: SetNull)
  // Counts (ImportCountsSchema) and the distinct-conflict summary (ImportResolutionPlanSchema) — jsonb.
  counts          Json
  conflictSummary Json?
  // SHA-256 of the imported file (never contents) for audit / undo correlation.
  fileHash        String?
  createdAt       DateTime     @default(now())

  @@index([sessionId, id])
  @@index([actorId])
  @@map("import_runs")
}

/// The entity an import targets — Asset is the only member in phase 1 (ADR-0069). Mirrors the
/// @lazyit/shared `ImportEntitySchema`; new entities are added here AND to that enum + a descriptor.
enum ImportEntity {
  ASSET
}

/// Lifecycle of an ImportSession — mirrors @lazyit/shared `ImportSessionStatusSchema`.
enum ImportSessionStatus {
  PENDING
  PARSING
  PARSED
  MAPPED
  DRY_RUN
  COMMITTING
  COMMITTED
  FAILED
  EXPIRED
}

/// Per-row lifecycle — mirrors @lazyit/shared `ImportRowStatusSchema`.
enum ImportRowStatus {
  PENDING
  COERCED
  VALID
  INVALID
  COMMITTED
  FAILED
  SKIPPED
}

// ─── Infra topology graph (ADR-0070) ─────────────────────────────────────────────────────────────
// A generic visual CMDB of the server estate: InfraNode (the things) + InfraEdge (typed, timestamped
// relationships). The full enum sets ship from day 1 so MVP/v1 never re-migrate; the model is generic
// on purpose (no platform-specific kinds). Enums mirror @lazyit/shared `schemas/infra.ts`.
// See docs/03-decisions/0070-infra-topology-graph.md.

/// What a node IS (ADR-0070 §2). Generic + extensible — a new kind is a one-line enum migration,
/// never a re-model. No platform-specific kinds (a k8s pod is a CONTAINER, a namespace a CLUSTER/OTHER).
enum InfraNodeKind {
  PHYSICAL_HOST
  VM
  CONTAINER
  CLUSTER // any logical grouping of hosts/nodes
  NETWORK_DEVICE
  STORAGE
  APPLIANCE
  OTHER
}

/// Live state of a node. The v2 agent's `lastReportedAt` liveness drives this (stale => OFFLINE);
/// manual until then.
enum InfraNodeStatus {
  ONLINE
  OFFLINE
  UNKNOWN
}

/// Provenance (ADR-0070 §4): hand-entered vs auto-discovered by the v2 reporting agent.
enum InfraNodeSource {
  MANUAL
  AGENT
}

/// Lifecycle (ADR-0070 §4): PENDING = in the v2 review tray, CONFIRMED = on the live map.
enum InfraNodeState {
  CONFIRMED
  PENDING
}

/// Typed relationship between two nodes (ADR-0070 §3). Direction/cardinality live in
/// @lazyit/shared (PLAUSIBLE_EDGE_TARGETS) and the partial unique indexes below.
enum InfraEdgeKind {
  RUNS_ON // source is hosted/executed by target — one active host per source (partial unique below)
  MEMBER_OF // source belongs to a logical group
  DEPENDS_ON // source needs target to function
  BACKS_UP_TO // source's data is backed up to target
  CONNECTS_TO // network adjacency — symmetric; API stores lower id as source (canonical-pair unique below)
}

/// A node: anything that appears on the map. Asset-backed by default (ADR-0070 §5 — inherits
/// owner/KB/secrets/warranty/shortcuts via the linked Asset). Mutable domain entity: createdAt +
/// updatedAt + deletedAt (soft delete = off the map, history kept; ADR-0006).
model InfraNode {
  id String @id @default(cuid())

  kind   InfraNodeKind
  label  String // canvas display name — always wins for display (ADR-0070 §5)
  status InfraNodeStatus @default(UNKNOWN)

  // Asset linkage — DEFAULT-ON. SetNull: deleting the asset detaches, never deletes the node
  // (audit > strict integrity). The default-asset create flow is API logic (ADR-0070 §5).
  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  // Access surface (NOT a network model — ADR-0070 scope cuts).
  ipAddress String? // primary IP, label-only (no validation/IPAM)
  shortcuts Json? // [{ label, url }] — SSH/web UI/console links (validated by zod in @lazyit/shared)
  specs     Json? // loose per-kind attrs (ADR-0007 posture)

  // Canvas layout (free-move). v1: one board, x/y on the node. Multi-board => join later.
  x Float?
  y Float?

  // Provenance + lifecycle (columns exist now; the agent that exercises them is v2 — ADR-0070 §4).
  source          InfraNodeSource @default(MANUAL)
  state           InfraNodeState  @default(CONFIRMED)
  reportingSource String? // which agent/host reported it (dedup scope)
  externalId      String? // platform id (vmid/container-id) for reconciliation
  lastReportedAt  DateTime? // agent liveness; stale => OFFLINE

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete = off the map, history kept

  edgesFrom InfraEdge[] @relation("EdgeSource")
  edgesTo   InfraEdge[] @relation("EdgeTarget")

  // Soft secret-handle references attached to this node (ADR-0073, #801). Metadata only (handle +
  // vaultId), NO FK to the SecretItem — mirrors KB chips + SecretAuditLog. INV-10: never a value.
  secretLinks InfraNodeSecretRef[]

  @@index([assetId])
  @@index([kind])
  @@index([state]) // the PENDING review-tray query
  // v2: partial UNIQUE (reportingSource, externalId) WHERE both NOT NULL — added with the agent
  // migration (the columns exist now, so it is a forward-only add, NOT a re-model). See ADR-0070 §4.
  // DO NOT add it in this foundation migration.
  @@map("infra_nodes")
}

/// An edge: a typed, timestamped relationship. Same DNA as AssetAssignment (ADR-0019) — append-style
/// lifecycle with startedAt/endedAt (a migration closes one edge, opens the next). Cascade on node
/// delete: an edge is meaningless without both endpoints and is NOT an audited domain entity (the
/// node and its Asset carry durable history). No deletedAt — it is not soft-deleted.
model InfraEdge {
  id        String        @id @default(cuid())
  sourceId  String
  source    InfraNode     @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId  String
  target    InfraNode     @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
  kind      InfraEdgeKind
  startedAt DateTime      @default(now())
  endedAt   DateTime? // null = active; migration = close one, open next

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Two raw-SQL PARTIAL UNIQUE indexes Prisma can't express live in the migration (ADR-0070 §3,
  // docs/05-runbooks/prisma-migrations.md §3):
  //   1. (sourceId) WHERE endedAt IS NULL AND kind = 'RUNS_ON' — one active host per source. ONLY
  //      RUNS_ON is constrained; MEMBER_OF/DEPENDS_ON/BACKS_UP_TO/CONNECTS_TO are legitimately many.
  //   2. (sourceId, targetId) WHERE kind = 'CONNECTS_TO' AND endedAt IS NULL — canonical-pair
  //      uniqueness for the symmetric CONNECTS_TO (the API canonicalizes lower id as source).
  @@index([sourceId])
  @@index([targetId])
  @@index([kind])
  @@map("infra_edges")
}

/// A SOFT secret-handle reference attached to an InfraNode (ADR-0073, #801) — the node→secret linkage
/// the drill-in `secretRefs` surfaces. Stores metadata only (the editable `handle` + its `vaultId`),
/// NO FK to the zero-knowledge SecretItem, mirroring the KB chip + SecretAuditLog soft-ref convention.
/// Because `handle` is editable and only LIVE-unique, a ref may drift on rename; it is RESOLVED at read
/// against live secret_items and a dangling ref (soft-deleted/renamed away) is dropped. INV-10:
/// `handle`/`vaultId` are metadata only — NEVER a value, envelope, or wrapped key. Cascade on node
/// delete (the link is meaningless without its node); not soft-deletable (a topology edit, not audited
/// domain data). See [[0073-infra-node-secret-linkage]].
model InfraNodeSecretRef {
  id        String    @id @default(cuid())
  nodeId    String
  node      InfraNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  // Soft refs to the zero-knowledge SecretItem (NO FK), mirroring KB chips + SecretAuditLog.
  // handle is editable + only live-unique => may drift on rename; resolved at read, dangling dropped.
  // INV-10: handle/vaultId are metadata only — never values.
  vaultId   String
  handle    String
  createdAt DateTime  @default(now())

  @@unique([nodeId, vaultId, handle])
  @@index([nodeId])
  @@map("infra_node_secret_refs")
}
