# Base URL of the lazyit API (NestJS). Read by lib/api/client.ts.
# Copy this file to .env and adjust as needed: cp .env.example .env
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Auth.js v5 (next-auth) — see ADR-0039 ────────────────────────────────────
#
# Generate AUTH_SECRET with:  openssl rand -base64 32
AUTH_SECRET=CHANGE_ME

# OIDC provider. Defaults to the bundled Zitadel (docs/05-runbooks/auth-bootstrap.md).
# BYOI: replace these three values to swap IdPs. No code changes needed.
#
# DEV QUICKSTART: run `bun run dev:fresh` from the repo root — it bootstraps Zitadel and writes
# AUTH_ISSUER, AUTH_CLIENT_ID, and AUTH_CLIENT_SECRET into your apps/web/.env automatically.
# You do NOT need to copy them by hand. The CHANGE_ME placeholders below are overwritten on first run.
# In dev, AUTH_ISSUER points to the local Zitadel instance (http://localhost:8080).
AUTH_ISSUER=http://localhost:8080
AUTH_CLIENT_ID=CHANGE_ME
AUTH_CLIENT_SECRET=CHANGE_ME

# The public URL Next.js is accessible at. Auth.js v5 reads AUTH_URL (NOT the v4-era NEXTAUTH_URL)
# to build the OIDC callback URL; it must match the redirect URI registered in your IdP.
AUTH_URL=http://localhost:3000

# Trust the host/proxy headers when computing the callback URL. Required behind Caddy / any reverse
# proxy (prod), and avoids the 0.0.0.0:3000 callback failure in dev. Keep this true.
AUTH_TRUST_HOST=true

# AUTH_INTERNAL_ISSUER — optional Docker split-DNS workaround (read by apps/web/auth.ts). Set ONLY
# when the web container cannot resolve the external AUTH_ISSUER host from inside the Docker network.
# When set, server-side OIDC calls (discovery / token / userinfo) are rewritten to this internal
# origin (with X-Forwarded-*); the browser-facing authorization redirect still uses AUTH_ISSUER.
# Unset in plain local dev. Example for the prod compose: http://zitadel:8080
# AUTH_INTERNAL_ISSUER=http://zitadel:8080
