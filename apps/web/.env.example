# Base URL of the lazyit API (NestJS). Read by lib/api/client.ts.
# Copy this file to .env and adjust as needed: cp .env.example .env
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Auth.js v5 (next-auth) — see ADR-0039 ────────────────────────────────────
#
# Generate AUTH_SECRET with:  openssl rand -base64 32
AUTH_SECRET=CHANGE_ME

# OIDC provider. Defaults to the bundled Zitadel (docs/05-runbooks/auth-bootstrap.md).
# BYOI: replace these three values to swap IdPs. No code changes needed.
# In dev, AUTH_ISSUER is the local Zitadel instance (started via docker compose).
AUTH_ISSUER=http://localhost:8080
AUTH_CLIENT_ID=CHANGE_ME
AUTH_CLIENT_SECRET=CHANGE_ME

# The public URL Next.js is accessible at. Auth.js uses this for OIDC callback URLs.
# Must match the redirect URI registered in your IdP.
NEXTAUTH_URL=http://localhost:3000
