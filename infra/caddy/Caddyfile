# lazyit reverse proxy — Caddy. See ADR-0026, ADR-0037.
#
# Two HTTPS site blocks:
#   1. {$LAZYIT_SITE_ADDRESS} — the lazyit web app + API (same-origin routing, ADR-0026).
#   2. auth.{$LAZYIT_DOMAIN}  — Zitadel IdP; Caddy auto-TLS covers it (ADR-0037).
#
# Automatic HTTPS: Caddy's INTERNAL CA for `localhost` (local prod-like), and Let's Encrypt
# for a real domain. Routing is SAME-ORIGIN: the browser calls /api/* and Caddy forwards it
# to the API, so the web image is domain-portable (NEXT_PUBLIC_API_URL=/api, baked at build).

{
	admin off
	# Real domain (Let's Encrypt): set an ACME contact email. Leave commented for local.
	# email {$LAZYIT_TLS_EMAIL}
}

# --- Zitadel IdP — auth subdomain (ADR-0037) -------------------------------------
# Zitadel runs on the internal Docker network without its own TLS (--tlsMode disabled).
# Caddy terminates HTTPS here and proxies to Zitadel's internal HTTP listener.
# Set LAZYIT_DOMAIN to your base domain (e.g. "lazyit.example.com") in .env.prod.
# Local prod-like: set LAZYIT_DOMAIN=localhost — Caddy uses its internal CA.
auth.{$LAZYIT_DOMAIN:localhost} {
	reverse_proxy zitadel:8080
}

# Site address. Local prod-like: unset -> "localhost" (internal CA, served on :443 -> host :8443).
# Real domain: set LAZYIT_SITE_ADDRESS=lazyit.example.com (publicly reachable :80/:443).
{$LAZYIT_SITE_ADDRESS:localhost} {
	encode zstd gzip

	# Swagger UI + raw OpenAPI live at the API's OWN /api/docs* — forward WITHOUT stripping.
	@apidocs path /api/docs*
	handle @apidocs {
		reverse_proxy api:3001
	}

	# /api/* -> API, stripping the /api prefix (e.g. /api/users -> /users), EXCEPT Auth.js
	# routes (/api/auth/*) which the Next.js web app owns (ADR-0039). They are excluded here
	# and fall through to the catch-all below -> web:3000.
	#
	# Why not a dedicated `handle @authjs { reverse_proxy web:3000 }`? It would be byte-identical
	# to the catch-all, and Caddy's Caddyfile adapter MERGES identical handle blocks — silently
	# dropping the /api/auth/* matcher, so those requests fall to @api and hit the API as 404.
	# Verified with `caddy adapt`. Excluding the path from @api is the reliable construction.
	@api {
		path /api/*
		not path /api/auth/*
	}
	handle @api {
		uri strip_prefix /api
		reverse_proxy api:3001
	}

	# Everything else — the web UI AND Auth.js's /api/auth/* — -> the Next.js web app.
	handle {
		reverse_proxy web:3000
	}
}
