# =============================================================================
# lazyit — production-like / self-hosted environment.  See ADR-0028 (secrets).
#
#   cp infra/env/.env.prod.example infra/env/.env.prod   # then fill in CHANGE_ME values
#   chmod 600 infra/env/.env.prod                         # protect it on the host
#
# .env.prod is GITIGNORED. NEVER commit real secrets. Replace EVERY "CHANGE_ME".
# Bring the stack up with (from the repo root) — --env-file is required (the `environment:` blocks
# use ${VAR} interpolation resolved by Compose at parse time):
#   docker compose -f compose.yaml -f infra/docker-compose.prod.yaml \
#     --profile prod --env-file infra/env/.env.prod up -d --build
# =============================================================================

# --- PostgreSQL (internal network only — its port is never published) -------
# Generate a strong password: openssl rand -base64 24   (or: tr -dc A-Za-z0-9 </dev/urandom | head -c 32)
# NEVER reuse a personal/weak password — this file is the master key to all data.
POSTGRES_USER=lazyit
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=lazyit

# --- API (NestJS) -----------------------------------------------------------
# Must point at the `db` service host and reuse the Postgres credentials above.
DATABASE_URL=postgresql://lazyit:CHANGE_ME_STRONG_PASSWORD@db:5432/lazyit?schema=public
PORT=3001
# Express `trust proxy` hop count (SEC-010). Behind Caddy the API has exactly ONE proxy hop, so set
# "1": `req.ip` then resolves to the VERIFIED client Caddy reports (Caddy's `trusted_proxies` drops a
# forged X-Forwarded-For from the public caller). This keys the /config/setup rate-limiter + the
# first-run audit IP. Leave UNSET only if the API is reached directly with no reverse proxy.
TRUST_PROXY=1
# Public site URL (the origin the browser uses). Local prod-like default below;
# for a real domain use https://lazyit.example.com (no trailing slash).
# Also used as Auth.js AUTH_URL (the web compose maps it) to pin the OIDC redirect_uri.
WEB_ORIGIN=https://localhost:8443
# Max upload size (MB) for the article import endpoint. Default 5 if unset.
MAX_IMPORT_SIZE_MB=5

# --- Valkey (ADR-0053) — BullMQ broker for async workers; internal service, never published -----
# Redis-protocol URL. Points at the `valkey` service on the internal network (port 6379 is never
# exposed to the host, like the DBs — SEC-005/ADR-0028).
REDIS_URL=redis://valkey:6379

# --- Applications Workflow Engine secrets (ADR-0054) -----------------------
# AES-256-GCM master key for the engine's OWN encrypted credential store (WorkflowSecret) — the per-app
# connector credentials. EXACTLY 32 bytes; generate with: openssl rand -hex 32  (→ 64 hex chars).
# A SECRET — never logged, never committed. The third recovery linchpin alongside POSTGRES_PASSWORD and
# ZITADEL_MASTERKEY: add it to the backup runbook. Losing it = losing every stored connector credential
# (recoverable only by re-entering them). The API FAILS LOUD AT BOOT if the engine is enabled and this
# is missing / the wrong length.
WORKFLOW_SECRET_KEY=CHANGE_ME_OPENSSL_RAND_HEX_32

# --- Caddy reverse proxy / TLS ---------------------------------------------
# Local prod-like: "localhost" -> Caddy internal CA (browser will warn until the CA is trusted).
# Real domain: set to your FQDN (must be publicly reachable on :80/:443 for Let's Encrypt).
LAZYIT_SITE_ADDRESS=localhost
# ACME contact email for Let's Encrypt on a real domain (also uncomment `email` in the Caddyfile).
# LAZYIT_TLS_EMAIL=ops@example.com

# Host ports Caddy publishes (high ports so they never clash with dev 3000/3001/5432).
LAZYIT_HTTP_PORT=8080
LAZYIT_HTTPS_PORT=8443

# --- Meilisearch (ADR-0035) — internal service; never publish port 7700 externally --------
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=CHANGE_ME_STRONG_MASTER_KEY
MEILI_ENV=production
MEILI_NO_ANALYTICS=true

# Base domain used to build the Zitadel auth subdomain in the Caddyfile (ADR-0037).
# Caddy serves Zitadel at auth.{LAZYIT_DOMAIN}. Set to your FQDN base, e.g. "lazyit.example.com".
# Local prod-like: set to "localhost" (Caddy internal CA covers auth.localhost too).
LAZYIT_DOMAIN=lazyit.example.com

# --- Zitadel IdP (prod) — bundled default IdP. See ADR-0037. ---------------
# Zitadel gets its own Postgres instance (separate from the app DB). Both containers
# run on the internal network only — neither is ever published to the host (ADR-0028).
# See docs/05-runbooks/auth-bootstrap.md for the bootstrap procedure.

# Zitadel's own Postgres credentials (shared by the zitadel_db and zitadel containers)
ZITADEL_DB_USER=zitadel
ZITADEL_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ZITADEL_DB_NAME=zitadel

# Master key — EXACTLY 32 bytes (Zitadel rejects anything shorter OR longer; not "min 32").
# Generate one that is exactly 32 chars (16 hex bytes -> 32 hex chars): openssl rand -hex 16
# NEVER reuse across environments. NEVER commit a real value. A wrong length = first-boot failure.
ZITADEL_MASTERKEY=CHANGE_ME_EXACTLY_32B_MASTERKEY!

# External hostname Zitadel advertises in tokens and redirects (no protocol prefix).
# Must match the Caddy auth subdomain: auth.{LAZYIT_DOMAIN}.
ZITADEL_EXTERNALDOMAIN=auth.lazyit.example.com

# First-boot admin user — created on start-from-init, only used once.
# Password must meet Zitadel complexity: min 8 chars, upper + lower + digit + symbol.
ZITADEL_ADMIN_USERNAME=admin
ZITADEL_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Zero-touch bootstrap (ADR-0043 Phase 3) — NO console clicking ----------
# On first boot, start-from-init ALSO creates a FirstInstance MACHINE user (granted IAM_OWNER) and
# exports its private key to /zitadel-secrets/bootstrap-key.json inside the shared zitadel_secrets
# volume. The `zitadel-bootstrap` one-shot sidecar then reads that key, authenticates to the
# Management API (Private-Key JWT), and IDEMPOTENTLY provisions the lazyit project + OIDC web app +
# the ADMIN/MEMBER/VIEWER project roles + a runtime service-account, writing two files BACK into the
# volume that api/web consume at startup:
#   - oidc-client.json : OIDC_ISSUER / OIDC_CLIENT_ID / OIDC_CLIENT_SECRET / OIDC_JWKS_URI / project id
#   - sa-key.json      : the runtime SA private key (read via ZITADEL_MGMT_SA_KEY_PATH below)
# => The operator NO LONGER hand-copies the OIDC client id/secret from the console (see §4 below).
# Optional overrides (defaults shown — usually leave unset):
# ZITADEL_BOOTSTRAP_USERNAME=zitadel-bootstrap   # FirstInstance machine-user login
# ZITADEL_PROJECT_NAME=lazyit                     # the provisioned project name
# ZITADEL_APP_NAME=lazyit-web                     # the provisioned OIDC app name
# ZITADEL_API_SA_USERNAME=lazyit-api              # the runtime write-back service-account login

# Where the API (ZitadelManagementService, Phase 2) reads the runtime SA key the sidecar wrote.
# Defaults to /zitadel-secrets/sa-key.json (the sidecar's output path); leave as-is for the bundled
# flow. The project id the API grants roles on is sourced from oidc-client.json (no manual var).
ZITADEL_MGMT_SA_KEY_PATH=/zitadel-secrets/sa-key.json

# Path the API + web read the sidecar's OIDC client file from (issuer/client_id/client_secret/jwks/
# project id). Defaults to /zitadel-secrets/oidc-client.json (the sidecar's output path on the shared
# read-only volume). Leave as-is for the bundled flow; irrelevant for BYOI (the file is absent).
# OIDC_CLIENT_FILE=/zitadel-secrets/oidc-client.json

# Project id the API grants ADMIN/MEMBER/VIEWER roles on. BUNDLED (zero-touch): LEAVE UNSET — the
# sidecar GENERATES it at first boot and writes it into oidc-client.json, which the API reads at
# startup. Set it ONLY for BYOI without the sidecar (a pin so the API fails clear if it drifts).
# ZITADEL_MGMT_PROJECT_ID=

# --- OIDC client ------------------------------------------------------------
# BUNDLED ZITADEL (zero-touch): the zitadel-bootstrap sidecar GENERATES the OIDC client id/secret AND
# the project id at first boot and writes them to oidc-client.json on the shared volume; the API +
# web read that file at startup when the env values are UNSET (ADR-0043 §4c). So in the bundled flow:
#   - set ONLY OIDC_ISSUER (and its AUTH_ISSUER mirror) to your external auth URL, and
#   - LEAVE OIDC_CLIENT_ID / OIDC_CLIENT_SECRET / AUTH_CLIENT_ID / AUTH_CLIENT_SECRET and the project
#     id UNSET (commented out below) — the sidecar provides them. No hand-copying from the console.
# BYOI: UNCOMMENT and set all of OIDC_CLIENT_ID/SECRET + the AUTH_* mirrors to your own IdP
# (Azure AD / Okta / Keycloak …) and remove the zitadel/zitadel_db/zitadel-bootstrap services — no
# code changes (ADR-0037). Explicit env always overrides the file.
OIDC_ISSUER=https://auth.lazyit.example.com
# OIDC_CLIENT_ID=CHANGE_ME       # BUNDLED: leave unset (sidecar provides). BYOI: set.
# OIDC_CLIENT_SECRET=CHANGE_ME   # BUNDLED: leave unset (sidecar provides). BYOI: set.

# Internal Zitadel URL for server-to-server calls (JWKS fetch, token exchange).
# The API and web containers cannot resolve the external auth subdomain via Docker DNS.
# These env vars route internal calls directly to the Zitadel container over HTTP (no TLS).
# Leave blank if your auth subdomain resolves inside Docker (e.g. real domain with split DNS).
# BUNDLED: the API also reads OIDC_JWKS_URI from oidc-client.json and the web DERIVES
# AUTH_INTERNAL_ISSUER from that file's JWKS origin when these are unset — so they are optional.
OIDC_JWKS_URI=http://zitadel:8080/oauth/v2/keys
AUTH_INTERNAL_ISSUER=http://zitadel:8080

# Auth.js (web) OIDC credentials. BUNDLED (zero-touch): leave AUTH_CLIENT_ID / AUTH_CLIENT_SECRET
# UNSET — the web reads them from oidc-client.json (mapped from OIDC_CLIENT_ID/SECRET) at startup.
# BYOI: uncomment and set to match the OIDC client registered in your IdP.
AUTH_ISSUER=https://auth.lazyit.example.com
# AUTH_CLIENT_ID=CHANGE_ME       # BUNDLED: leave unset (sidecar provides). BYOI: set.
# AUTH_CLIENT_SECRET=CHANGE_ME   # BUNDLED: leave unset (sidecar provides). BYOI: set.

# Auth.js session secret — encrypts the session JWT cookie. MANDATORY.
# Generate with: openssl rand -base64 33
# AUTH_TRUST_HOST is set to "true" in the compose (web runs behind Caddy — ADR-0039).
AUTH_SECRET=CHANGE_ME_RANDOM_33_BYTES_BASE64

# --- Automated backups (OPT-IN sidecar) — see docs/05-runbooks/backups.md ---
# The `backup` profile service runs cron + pg_dump for BOTH databases to host ./backups, then
# prunes old dumps. Disabled unless you start it (it needs BOTH the prod and backup profiles):
#   docker compose -f compose.yaml -f infra/docker-compose.prod.yaml --env-file infra/env/.env.prod \
#     --profile prod --profile backup up -d backup
# All three are optional (defaults shown). The sidecar does NOT back up THIS file — copy it
# off-host yourself; it is the DR linchpin (holds ZITADEL_MASTERKEY).
# BACKUP_CRON=30 2 * * *        # crontab syntax. Default: daily at 02:30.
# BACKUP_RETENTION_DAYS=14      # prune dumps older than N days. Default: 14.
# Optional offsite copy — OFF unless set. Runs once per dump with the dump path as "$1".
# Stays local-disk-only by default (no mandatory cloud — ADR-0028). Example with rclone:
# BACKUP_OFFSITE_CMD=rclone copy "$1" offsite:lazyit/
