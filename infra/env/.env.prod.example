# =============================================================================
# lazyit — production-like / self-hosted environment.  See ADR-0028 (secrets).
#
#   cp infra/env/.env.prod.example infra/env/.env.prod   # then fill in CHANGE_ME values
#   chmod 600 infra/env/.env.prod                         # protect it on the host
#
# .env.prod is GITIGNORED. NEVER commit real secrets. Replace EVERY "CHANGE_ME".
# Each service loads this file via `env_file:`, so bring the stack up with (from the repo root):
#   docker compose -f infra/docker-compose.prod.yml up -d --build
# To override the host ports below, prepend `--env-file infra/env/.env.prod` to that command.
# =============================================================================

# --- PostgreSQL (internal network only — its port is never published) -------
POSTGRES_USER=lazyit
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=lazyit

# --- API (NestJS) -----------------------------------------------------------
# Must point at the `db` service host and reuse the Postgres credentials above.
DATABASE_URL=postgresql://lazyit:CHANGE_ME_STRONG_PASSWORD@db:5432/lazyit?schema=public
PORT=3001
# Public site URL (the origin the browser uses). Local prod-like default below;
# for a real domain use https://lazyit.example.com (no trailing slash).
WEB_ORIGIN=https://localhost:8443
# Max upload size (MB) for the article import endpoint. Default 5 if unset.
MAX_IMPORT_SIZE_MB=5

# --- Caddy reverse proxy / TLS ---------------------------------------------
# Local prod-like: "localhost" -> Caddy internal CA (browser will warn until the CA is trusted).
# Real domain: set to your FQDN (must be publicly reachable on :80/:443 for Let's Encrypt).
LAZYIT_SITE_ADDRESS=localhost
# ACME contact email for Let's Encrypt on a real domain (also uncomment `email` in the Caddyfile).
# LAZYIT_TLS_EMAIL=ops@example.com

# Host ports Caddy publishes (high ports so they never clash with dev 3000/3001/5432).
LAZYIT_HTTP_PORT=8080
LAZYIT_HTTPS_PORT=8443

# --- Meilisearch (ADR-0035) — internal service; never publish port 7700 externally --------
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=CHANGE_ME_STRONG_MASTER_KEY
MEILI_ENV=production
MEILI_NO_ANALYTICS=true

# Base domain used to build the Zitadel auth subdomain in the Caddyfile (ADR-0037).
# Caddy serves Zitadel at auth.{LAZYIT_DOMAIN}. Set to your FQDN base, e.g. "lazyit.example.com".
# Local prod-like: set to "localhost" (Caddy internal CA covers auth.localhost too).
LAZYIT_DOMAIN=lazyit.example.com

# --- Zitadel IdP (prod) — bundled default IdP. See ADR-0037. ---------------
# Zitadel gets its own Postgres instance (separate from the app DB). Both containers
# run on the internal network only — neither is ever published to the host (ADR-0028).
# See docs/05-runbooks/auth-bootstrap.md for the bootstrap procedure.

# Zitadel's own Postgres credentials (shared by the zitadel_db and zitadel containers)
ZITADEL_DB_USER=zitadel
ZITADEL_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ZITADEL_DB_NAME=zitadel

# Master key — min 32 chars. Generate with: tr -dc A-Za-z0-9 </dev/urandom | head -c 32
# NEVER reuse across environments. NEVER commit a real value.
ZITADEL_MASTERKEY=CHANGE_ME_32_CHARS_MINIMUM_STRONG_KEY

# External hostname Zitadel advertises in tokens and redirects (no protocol prefix).
# Must match the Caddy auth subdomain: auth.{LAZYIT_DOMAIN}.
ZITADEL_EXTERNALDOMAIN=auth.lazyit.example.com

# First-boot admin user — created on start-from-init, only used once.
# Password must meet Zitadel complexity: min 8 chars, upper + lower + digit + symbol.
ZITADEL_ADMIN_USERNAME=admin
ZITADEL_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- OIDC client (set AFTER Zitadel is bootstrapped) -----------------------
# See docs/05-runbooks/auth-bootstrap.md for how to get these values.
# The API reads these to validate OIDC tokens from the IdP.
# BYOI: swapping to Azure AD / Okta / Keycloak only requires changing these 3 vars.
# No code changes needed — the backend speaks standard OIDC (ADR-0037).
OIDC_ISSUER=https://auth.lazyit.example.com
OIDC_CLIENT_ID=CHANGE_ME
OIDC_CLIENT_SECRET=CHANGE_ME

# Internal Zitadel URL for server-to-server calls (JWKS fetch, token exchange).
# The API and web containers cannot resolve the external auth subdomain via Docker DNS.
# These env vars route internal calls directly to the Zitadel container over HTTP (no TLS).
# Leave blank if your auth subdomain resolves inside Docker (e.g. real domain with split DNS).
OIDC_JWKS_URI=http://zitadel:8080/oauth/v2/keys
AUTH_INTERNAL_ISSUER=http://zitadel:8080

# Auth.js (web) OIDC credentials — must match the OIDC client registered in Zitadel.
AUTH_ISSUER=https://auth.lazyit.example.com
AUTH_CLIENT_ID=CHANGE_ME
AUTH_CLIENT_SECRET=CHANGE_ME
